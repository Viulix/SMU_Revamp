<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SMU_Revamp.ViewModels"
        xmlns:models="using:SMU_Revamp.Models"
        xmlns:views="using:SMU_Revamp.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
        x:Class="SMU_Revamp.Views.DefaultsWindow"
        x:DataType="vm:DefaultsViewModel"
        Icon="/Assets/tf_logo_rgb_en.ico"
        Title="Edit Measurement Defaults"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        CanResize="True"
        Width="600"
        Height="500">

    <Design.DataContext>
        <vm:DefaultsViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="*, Auto">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Vertical" Margin="20" Spacing="15">
            <!-- Warning Disclaimer Box -->
            <Border Background="#FEEBEE" BorderBrush="#EF5350" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,5">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="⚠️" FontSize="20" VerticalAlignment="Center" />
                    <TextBlock Text="Warning: Modifying default parameter values changes the baseline parameters loaded at application startup. Ensure these values match your instrument's safety thresholds."
                               Foreground="#C62828"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Width="480" />
                </StackPanel>
            </Border>

            <!-- Plan Selector -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Measurement Plan:" Width="150" VerticalAlignment="Center" FontWeight="Bold" />
                <ComboBox ItemsSource="{Binding MeasurementPlans}"
                          SelectedItem="{Binding SelectedPlan}"
                          Width="200">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <TextBlock Text="{Binding SelectedPlan.Description}" 
                       TextWrapping="Wrap" 
                       FontStyle="Italic" 
                       Opacity="0.7" 
                       Margin="0,5,0,10" />

            <Separator Margin="0,5" />

            <!-- Dynamic Parameters editor -->
            <TextBlock Text="Default Values Configuration" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,5" />
            
            <ItemsControl ItemsSource="{Binding SelectedPlan.Parameters}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:MeasurementParameter">
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10" ToolTip.Tip="{Binding Tooltip}">
                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <ContentControl Grid.Column="1" Content="{Binding}" VerticalAlignment="Center">
                                <ContentControl.ContentTemplate>
                                    <views:ParameterTemplateSelector>
                                        <views:ParameterTemplateSelector.TextTemplate>
                                            <DataTemplate x:DataType="models:MeasurementParameter">
                                                <views:ParameterTextBox Text="{Binding Value, Mode=TwoWay}" Width="150" />
                                            </DataTemplate>
                                        </views:ParameterTemplateSelector.TextTemplate>
                                        <views:ParameterTemplateSelector.CheckboxTemplate>
                                            <DataTemplate x:DataType="models:MeasurementParameter">
                                                <CheckBox IsChecked="{Binding Value, Mode=TwoWay}" />
                                            </DataTemplate>
                                        </views:ParameterTemplateSelector.CheckboxTemplate>
                                        <views:ParameterTemplateSelector.DropdownTemplate>
                                            <DataTemplate x:DataType="models:MeasurementParameter">
                                                <ComboBox ItemsSource="{Binding Options}" 
                                                          SelectedItem="{Binding Value, Mode=TwoWay}" 
                                                          Width="200" />
                                            </DataTemplate>
                                        </views:ParameterTemplateSelector.DropdownTemplate>
                                    </views:ParameterTemplateSelector>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Separator Margin="0,10" />

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="#2E7D32"
                           FontWeight="SemiBold" />
                <Button Content="Close" Click="CloseButton_Click" Classes="Tertiary" Padding="15,8" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>

    <!-- Unsaved Changes Bar -->
    <Border Grid.Row="1" 
            IsVisible="{Binding HasUnsavedChanges}" 
            Background="Black" 
            Padding="16,12" 
            Margin="20,0,20,20" 
            CornerRadius="8"
            BoxShadow="0 4 10 0 #40000000">
        <Border.Styles>
            <Style Selector="Button.DiscardBtn">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>
            <Style Selector="Button.DiscardBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#333333" />
                <Setter Property="TextBlock.Foreground" Value="White" />
            </Style>
            
            <Style Selector="Button.SaveBtn">
                <Setter Property="Background" Value="White" />
                <Setter Property="Foreground" Value="Black" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Padding" Value="15,8" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>
            <Style Selector="Button.SaveBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#E0E0E0" />
                <Setter Property="TextBlock.Foreground" Value="Black" />
            </Style>
        </Border.Styles>

        <Grid ColumnDefinitions="*, Auto">
            <TextBlock Grid.Column="0" 
                       Text="Careful - you have unsaved changes!" 
                       Foreground="White" 
                       FontWeight="Bold" 
                       VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                <Button Classes="DiscardBtn" Content="Discard" Command="{Binding DiscardChangesCommand}" />
                <Button Classes="SaveBtn" Content="Save Changes" Command="{Binding SaveDefaultsCommand}" />
            </StackPanel>
        </Grid>
    </Border>
    </Grid>
</Window>
