<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SMU_Revamp.ViewModels"
        xmlns:views="using:SMU_Revamp.Views"
        xmlns:models="using:SMU_Revamp.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SMU_Revamp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SMU_Revamp"
        WindowState="Maximized">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
        to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Header with Settings and Debug Buttons -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="20,10,20,0" Spacing="10" HorizontalAlignment="Right">
            <Button Content="Debug" Click="DebugButton_Click" Classes="Secondary" Padding="10,5" />
            <Button Content="Defaults" Click="DefaultsButton_Click" Classes="Secondary" Padding="10,5" />
            <Button Content="Settings" Click="SettingsButton_Click" Classes="Primary" Padding="10,5" />
        </StackPanel>

        <!-- Main Content with Tabs -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}" Margin="20" Padding="20">
            <TabItem Header="Configuration">
                <ScrollViewer Margin="20" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="20">
                        <WrapPanel Orientation="Horizontal">
                            <!-- Target Contact -->
                            <StackPanel Spacing="10" Margin="10,0,40,20" Width="300">
                                <TextBlock Text="Target Contact" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,5" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Cell:" Width="120" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding TargetCell}" PlaceholderText="e.g. 0101" Width="150" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Row:" Width="120" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding TargetRow}" PlaceholderText="e.g. 1" Width="150" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Column:" Width="120" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding TargetColumn}" PlaceholderText="e.g. 1" Width="150" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Contact:" Width="120" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding TargetContact}" PlaceholderText="e.g. 1" Width="150" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Stay Here:" Width="120" VerticalAlignment="Center" />
                                    <CheckBox IsChecked="{Binding StayHere}" />
                                </StackPanel>
                                <Button Content="Go To Contact" Command="{Binding GoToContactCommand}" Classes="Primary" Width="150" Margin="0,10,0,0" />
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#D32F2F" TextWrapping="Wrap" MaxWidth="300" HorizontalAlignment="Left" />
                            </StackPanel>

                            <!-- Manual Move -->
                            <StackPanel Spacing="10" Margin="10,0,40,20" Width="330">
                                <TextBlock Text="Manual Move" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,5" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="X Position:" Width="120" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding MoveX}" PlaceholderText="e.g. 100" Width="100" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Y Position:" Width="120" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding MoveY}" PlaceholderText="e.g. 100" Width="100" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                                    <Button Content="Move Relative" Command="{Binding MoveRelativeCommand}" Classes="Secondary" Width="150" />
                                    <Button Content="Move Absolute" Command="{Binding MoveAbsoluteCommand}" Classes="Secondary" Width="150" />
                                </StackPanel>
                            </StackPanel>

                            <!-- File Storing Info -->
                            <StackPanel Spacing="10" Margin="10,0,0,20" Width="320">
                                <TextBlock Text="File Storing Info" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,5" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Profile:" Width="100" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding Settings.Profile}" Width="200" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Sample Name:" Width="100" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding Settings.SampleName}" Width="200" />
                                </StackPanel>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Viewer">
                <ScrollViewer Margin="20">
                    <StackPanel Spacing="16">
                        <Button Content="Export Data to CSV" 
                                Click="ExportCsvButton_Click"
                                IsEnabled="{Binding HasCurvePoints}"
                                Classes="Secondary" 
                                HorizontalAlignment="Right" />

                        <views:CurvePlotView Title="I/U Curve - Linear"
                                             XAxisLabel="{Binding XAxisTitle}"
                                             YAxisLabel="Current (A)"
                                             Points="{Binding CurvePoints}"
                                             Height="340" />

                        <views:CurvePlotView Title="I/U Curve - Logarithmic"
                                             XAxisLabel="{Binding XAxisTitle}"
                                             YAxisLabel="Current (A)"
                                             Points="{Binding CurvePoints}"
                                             LogarithmicY="True"
                                             Height="340" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Measurements">
                <ScrollViewer Margin="20" HorizontalScrollBarVisibility="Disabled">
                    <Grid ColumnDefinitions="1.4*, *" RowDefinitions="Auto, *" Margin="10">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Measurement Configuration" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Measurement Status &amp; Diagnostics" FontSize="18" FontWeight="SemiBold" Margin="20,0,0,0" />
                        
                        <!-- Left Column: Configuration -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="10" Margin="10,15,10,0" MaxWidth="800">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Measurement Plan:" Width="150" VerticalAlignment="Center" />
                                <ComboBox ItemsSource="{Binding MeasurementPlans}"
                                          SelectedItem="{Binding SelectedPlan}"
                                          Width="200">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <TextBlock Text="{Binding SelectedPlan.Description}" 
                                       TextWrapping="Wrap" 
                                       FontStyle="Italic" 
                                       Opacity="0.7" 
                                       Margin="0,5,0,15" />

                            <ItemsControl ItemsSource="{Binding SelectedPlanSections}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ParameterSection">
                                        <StackPanel Spacing="5" Margin="0,0,20,15" Width="370">
                                            <!-- Section Header -->
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="11" 
                                                       FontWeight="Bold" 
                                                       Foreground="#777777" 
                                                       Margin="0,5,0,5" 
                                                       IsVisible="{Binding HasName}" />
                                            
                                            <!-- Parameters in this Section -->
                                            <ItemsControl ItemsSource="{Binding Parameters}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:MeasurementParameter">
                                                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10" ToolTip.Tip="{Binding Tooltip}">
                                                            <TextBlock Text="{Binding DisplayName}" Width="150" VerticalAlignment="Center" />
                                                            <ContentControl Content="{Binding}">
                                                                <ContentControl.ContentTemplate>
                                                                    <views:ParameterTemplateSelector>
                                                                        <views:ParameterTemplateSelector.TextTemplate>
                                                                            <DataTemplate x:DataType="models:MeasurementParameter">
                                                                                <TextBox Text="{Binding Value, Mode=TwoWay}" Width="150" />
                                                                            </DataTemplate>
                                                                        </views:ParameterTemplateSelector.TextTemplate>
                                                                        <views:ParameterTemplateSelector.CheckboxTemplate>
                                                                            <DataTemplate x:DataType="models:MeasurementParameter">
                                                                                <CheckBox IsChecked="{Binding Value, Mode=TwoWay}" />
                                                                            </DataTemplate>
                                                                        </views:ParameterTemplateSelector.CheckboxTemplate>
                                                                        <views:ParameterTemplateSelector.DropdownTemplate>
                                                                            <DataTemplate x:DataType="models:MeasurementParameter">
                                                                                <ComboBox ItemsSource="{Binding Options}" 
                                                                                          SelectedItem="{Binding Value, Mode=TwoWay}" 
                                                                                          Width="200" />
                                                                            </DataTemplate>
                                                                        </views:ParameterTemplateSelector.DropdownTemplate>
                                                                    </views:ParameterTemplateSelector>
                                                                </ContentControl.ContentTemplate>
                                                            </ContentControl>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <CheckBox Content="Switch to Viewer tab automatically"
                                      IsChecked="{Binding AutoSwitchToViewer}"
                                      Margin="0,10,0,0" />

                            <CheckBox Content="Automatically save measurements"
                                      IsChecked="{Binding AutoSaveMeasurements}"
                                      Margin="0,5,0,0" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="Run Measurement" 
                                        Command="{Binding RunMeasurementCommand}" 
                                        IsEnabled="{Binding !IsMeasuring}"
                                        Classes="Primary" 
                                        Width="180" 
                                        Margin="0,15,0,0" />

                                <Button Content="Export to CSV" 
                                        Click="ExportCsvButton_Click"
                                        IsEnabled="{Binding HasCurvePoints}"
                                        Classes="Secondary" 
                                        Width="150" 
                                        Margin="0,15,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Column: Status -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="15" Margin="20,15,10,0" MaxWidth="650" HorizontalAlignment="Left">
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="15" Background="#F9F9F9" MinWidth="450" MinHeight="150">
                                <TextBlock Text="{Binding MeasurementStatus}" 
                                           FontFamily="Courier New" 
                                           FontSize="12" 
                                           TextWrapping="Wrap" />
                            </Border>

                            <StackPanel Spacing="5" IsVisible="{Binding IsMeasuringSweep}">
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="Sweep Progress" FontSize="11" FontWeight="SemiBold" Foreground="#666666" />
                                    <TextBlock Grid.Column="1" Text="{Binding MeasurementProgressText}" FontSize="11" FontWeight="SemiBold" Foreground="#333333" />
                                </Grid>
                                <ProgressBar Minimum="0" 
                                             Maximum="100" 
                                             Value="{Binding MeasurementProgress}" 
                                             IsIndeterminate="{Binding IsProgressIndeterminate}" 
                                             Height="8" 
                                             CornerRadius="4"
                                             Foreground="Black"
                                             Background="#E0E0E0" />
                            </StackPanel>

                            <TextBlock Text="{Binding WarningMessage}" 
                                       Foreground="#E65100" 
                                       TextWrapping="Wrap" 
                                       MaxWidth="400" 
                                       HorizontalAlignment="Left"
                                       IsVisible="{Binding HasWarningMessage}" />

                            <TextBlock Text="{Binding ErrorMessage}" 
                                       Foreground="#D32F2F" 
                                       TextWrapping="Wrap" 
                                       MaxWidth="400" 
                                       HorizontalAlignment="Left" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>