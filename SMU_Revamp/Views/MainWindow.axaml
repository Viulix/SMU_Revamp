<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SMU_Revamp.ViewModels"
        xmlns:views="using:SMU_Revamp.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SMU_Revamp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SMU_Revamp">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
        to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Header with Settings and Debug Buttons -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="20,10,20,0" Spacing="10" HorizontalAlignment="Right">
            <Button Content="Debug" Click="DebugButton_Click" Classes="Secondary" Padding="10,5" />
            <Button Content="⚙ Settings" Click="SettingsButton_Click" Classes="Secondary" Padding="10,5" />
        </StackPanel>

        <!-- Main Content with Tabs -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}" Margin="20" Padding="20">
            <TabItem Header="Configuration">
                <ScrollViewer Margin="20">
                    <StackPanel Spacing="20">
                        <TextBlock Text="Target Contact" FontSize="18" FontWeight="SemiBold" />
                        <StackPanel Spacing="10" Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Zelle:" Width="120" VerticalAlignment="Center" />
                                <TextBox Text="{Binding TargetCell}" Width="150" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Reihe:" Width="120" VerticalAlignment="Center" />
                                <TextBox Text="{Binding TargetRow}" Width="150" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Spalte:" Width="120" VerticalAlignment="Center" />
                                <TextBox Text="{Binding TargetColumn}" Width="150" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Kontakt:" Width="120" VerticalAlignment="Center" />
                                <TextBox Text="{Binding TargetContact}" Width="150" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Stay Here:" Width="120" VerticalAlignment="Center" />
                                <CheckBox IsChecked="{Binding StayHere}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Debugging:" Width="120" VerticalAlignment="Center" />
                                <CheckBox IsChecked="{Binding Debugging}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Adv Path A:" Width="120" VerticalAlignment="Center" />
                                <TextBox Text="{Binding AdvPathA}" Width="200" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Adv Path B:" Width="120" VerticalAlignment="Center" />
                                <TextBox Text="{Binding AdvPathB}" Width="200" />
                            </StackPanel>
                            <Button Content="Go To Contact" Command="{Binding GoToContactCommand}" Classes="Primary" Width="150" Margin="0,10,0,0" />
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#D32F2F" TextWrapping="Wrap" MaxWidth="400" HorizontalAlignment="Left" />
                        </StackPanel>

                        <Separator Margin="0,10" />

                        <TextBlock Text="File Storing Info" FontSize="18" FontWeight="SemiBold" />
                        <StackPanel Spacing="10" Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Profil:" Width="120" VerticalAlignment="Center" />
                                <TextBox Text="{Binding Settings.Profil}" Width="200" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Probename:" Width="120" VerticalAlignment="Center" />
                                <TextBox Text="{Binding Settings.Probename}" Width="200" />
                            </StackPanel>
                        </StackPanel>
                        
                        <Button Content="Save Configuration" Command="{Binding SaveSettingsCommand}" Classes="Primary" Padding="10,5" HorizontalAlignment="Left" Margin="0,10,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Viewer">
                <ScrollViewer Margin="20">
                    <StackPanel Spacing="16">
                        <Button Content="Export Data to CSV" 
                                Click="ExportCsvButton_Click"
                                IsEnabled="{Binding HasCurvePoints}"
                                Classes="Secondary" 
                                HorizontalAlignment="Right" />

                        <views:CurvePlotView Title="I/U Curve - Linear"
                                             XAxisLabel="Voltage (V)"
                                             YAxisLabel="Current (A)"
                                             Points="{Binding CurvePoints}"
                                             Height="340" />

                        <views:CurvePlotView Title="I/U Curve - Logarithmic"
                                             XAxisLabel="Voltage (V)"
                                             YAxisLabel="Current (A)"
                                             Points="{Binding CurvePoints}"
                                             LogarithmicY="True"
                                             Height="340" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Measurements">
                <ScrollViewer Margin="20">
                    <StackPanel Spacing="20">
                        <TextBlock Text="I-V Sweep Configuration" FontSize="18" FontWeight="SemiBold" />
                        
                        <StackPanel Spacing="10" Margin="10,0,0,0" MaxWidth="500" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Channel:" Width="150" VerticalAlignment="Center" />
                                <TextBox Text="{Binding SweepChannel}" Width="150" />
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Start Voltage (V):" Width="150" VerticalAlignment="Center" />
                                <TextBox Text="{Binding SweepStart}" Width="150" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Stop Voltage (V):" Width="150" VerticalAlignment="Center" />
                                <TextBox Text="{Binding SweepStop}" Width="150" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Points:" Width="150" VerticalAlignment="Center" />
                                <TextBox Text="{Binding SweepPoints}" Width="150" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Compliance (A):" Width="150" VerticalAlignment="Center" />
                                <TextBox Text="{Binding SweepCompliance}" Width="150" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="ADC Samples (PLC):" Width="150" VerticalAlignment="Center" />
                                <TextBox Text="{Binding SweepAdcSamples}" Width="150" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Sweep Mode:" Width="150" VerticalAlignment="Center" />
                                <ComboBox ItemsSource="{Binding SweepModes}"
                                          SelectedItem="{Binding SelectedSweepMode}"
                                          Width="200" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="Run Measurement" 
                                        Command="{Binding RunMeasurementCommand}" 
                                        IsEnabled="{Binding !IsMeasuring}"
                                        Classes="Primary" 
                                        Width="180" 
                                        Margin="0,15,0,0" />

                                <Button Content="Export to CSV" 
                                        Click="ExportCsvButton_Click"
                                        IsEnabled="{Binding HasCurvePoints}"
                                        Classes="Secondary" 
                                        Width="150" 
                                        Margin="0,15,0,0" />
                            </StackPanel>

                            <Separator Margin="0,15" />

                            <TextBlock Text="Measurement Status" FontSize="14" FontWeight="SemiBold" />
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="10" Background="#F9F9F9">
                                <TextBlock Text="{Binding MeasurementStatus}" 
                                           FontFamily="Courier New" 
                                           FontSize="12" 
                                           TextWrapping="Wrap" />
                            </Border>

                            <TextBlock Text="{Binding ErrorMessage}" 
                                       Foreground="#D32F2F" 
                                       TextWrapping="Wrap" 
                                       MaxWidth="400" 
                                       HorizontalAlignment="Left" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>