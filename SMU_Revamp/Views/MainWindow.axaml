<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SMU_Revamp.ViewModels"
        xmlns:views="using:SMU_Revamp.Views"
        xmlns:models="using:SMU_Revamp.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SMU_Revamp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/tf_logo_rgb_en.ico"
        Title="Wafer Measurement Tool"
        WindowState="Maximized">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
        to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="Background" Value="Black" />
        </Style>
    </Window.Styles>

    <Grid>
        <DockPanel>
        <!-- Header with Settings and Debug Buttons -->
        <Grid DockPanel.Dock="Top" Margin="20,10,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Profile:" VerticalAlignment="Center" FontWeight="SemiBold" />
                <TextBox Text="{Binding Settings.Profile}" Width="150" />
                
                <TextBlock Text="Sample:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="10,0,0,0" />
                <TextBox Text="{Binding Settings.SampleName}" Width="150" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button Content="Settings" Click="SettingsButton_Click" Classes="Primary" Padding="10,5" />
            </StackPanel>
        </Grid>

        <!-- Global Progress Bar Panel (Visible during active measurement or wafer scan) -->
        <Border DockPanel.Dock="Top" 
                IsVisible="{Binding IsGlobalProgressVisible}"
                Background="#EEF2F6"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1"
                Padding="20,12"
                Margin="20,10,20,0"
                CornerRadius="8">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Path Fill="#4B5563" Data="M19 8l-4 4h3c0 3.31-2.69 6-6 6-1.01 0-1.97-.25-2.8-.7l-1.46 1.46C8.97 19.54 10.43 20 12 20c4.42 0 8-3.58 8-8h3l-4-4zM6 12c0-3.31 2.69-6 6-6 1.01 0 1.97.25 2.8.7l1.46-1.46C15.03 4.46 13.57 4 12 4c-4.42 0-8 3.58-8 8H1l4 4 4-4H6z" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <TextBlock Text="{Binding GlobalProgressTitle}" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                    <TextBlock Text="—" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding GlobalProgressStatusText}" Foreground="#4B5563" VerticalAlignment="Center"/>
                </StackPanel>
                
                <ProgressBar Grid.Column="1" 
                             Minimum="0" 
                             Maximum="100" 
                             Value="{Binding GlobalProgressValue}" 
                             IsIndeterminate="{Binding IsGlobalProgressIndeterminate}" 
                             Height="10" 
                             CornerRadius="5"
                             Foreground="#10B981"
                             Background="#D1D5DB"
                             Margin="20,0"
                             VerticalAlignment="Center"/>
                             
                <Button Grid.Column="2" 
                        Content="Stop Scan" 
                        Command="{Binding RequestStopScanCommand}" 
                        IsVisible="{Binding IsScanningWafer}"
                        Classes="Danger" 
                        Padding="15,6"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main Content with Tabs -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}" Margin="20" Padding="20">
            <TabItem Header="Viewer">
                <Grid>
                    <!-- Empty State Placeholder (No Data Loaded) -->
                    <Border IsVisible="{Binding !IsPlottedPlanLoaded}"
                            Background="#F9FAFB"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="40"
                            Margin="30"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="500">
                        <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- Visual Circle / Icon Representative (Chart Icon) -->
                            <Border Width="80" Height="80" CornerRadius="40" Background="#EEF2F6" HorizontalAlignment="Center">
                                <Path Fill="#6B7280" Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" Width="36" Height="36" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            
                            <TextBlock Text="No measurement data loaded" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="#1F2937" 
                                       HorizontalAlignment="Center" 
                                       TextAlignment="Center"/>
                                       
                            <TextBlock Text="Please execute a measurement in the Measurements tab, import a CSV/TSV measurement file, or load from the Database to view the plots." 
                                       TextWrapping="Wrap" 
                                       FontSize="14" 
                                       Foreground="#4B5563" 
                                       HorizontalAlignment="Center" 
                                       TextAlignment="Center"
                                       LineHeight="20"/>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,10,0,0">
                                <Button Content="Import File" 
                                        Click="ImportFileButton_Click" 
                                        Classes="Primary" 
                                        Padding="20,10" />
                                <Button Content="Load from DB" 
                                        Click="LoadFromDatabaseButton_Click" 
                                        Classes="Secondary" 
                                        Padding="20,10" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Normal Viewer UI -->
                    <Grid IsVisible="{Binding IsPlottedPlanLoaded}" Margin="20" RowDefinitions="Auto, *">
                        <!-- Top Control Bar -->
                        <Grid Grid.Row="0" Margin="0,0,0,10" ColumnDefinitions="*, Auto" VerticalAlignment="Center">
                                <!-- Middle: Plot Controls -->
                                <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,15,10">
                                        <TextBlock Text="Plot View:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#4B5563"/>
                                        <ComboBox ItemsSource="{Binding AvailablePlotViews}"
                                                  SelectedItem="{Binding SelectedPlotView}"
                                                  Width="150" Height="32" VerticalContentAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,15,10">
                                        <TextBlock Text="Plot Style:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#4B5563"/>
                                        <ComboBox ItemsSource="{Binding AvailablePlotStyles}"
                                                  SelectedItem="{Binding SelectedPlotStyleString}"
                                                  Width="150" Height="32" VerticalContentAlignment="Center"/>
                                    </StackPanel>

                                    <Button Content="Advanced Plot Settings" 
                                            Click="OpenAdvancedPlotSettingsButton_Click"
                                            Classes="Secondary" 
                                            Height="32"
                                            Padding="15,0"
                                            VerticalContentAlignment="Center" Margin="0,0,15,10" />

                                    <CheckBox Content="Logarithmic X" IsChecked="{Binding IsViewerLogarithmicX}" VerticalAlignment="Center" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,15,10"/>
                                </WrapPanel>

                                <!-- Right: Action Buttons -->
                                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <Button Content="Import File" 
                                            Click="ImportFileButton_Click"
                                            Classes="Primary" 
                                            Height="32"
                                            Padding="15,0"
                                            VerticalContentAlignment="Center" Margin="0,0,15,10" />

                                    <Button Content="Load from DB" 
                                            Click="LoadFromDatabaseButton_Click"
                                            Classes="Secondary" 
                                            Height="32"
                                            Padding="15,0"
                                            VerticalContentAlignment="Center" Margin="0,0,15,10" />

                                    <Button Content="Export" 
                                            Click="ExportCsvButton_Click"
                                            IsEnabled="{Binding HasCurvePoints}"
                                            Classes="Secondary" 
                                            Height="32"
                                            Padding="15,0"
                                            VerticalContentAlignment="Center" Margin="0,0,15,10" />

                                    <Button Content="Upload to DB" 
                                            Click="UploadToDatabaseButton_Click"
                                            IsEnabled="{Binding HasCurvePoints}"
                                            Classes="Secondary" 
                                            Height="32"
                                            Padding="15,0"
                                            VerticalContentAlignment="Center" Margin="0,0,0,10" />
                                </WrapPanel>
                        </Grid>

                            <DockPanel Grid.Row="1" Margin="0,15,0,0">
                                <!-- Measurement Settings (Right) -->
                                <Border DockPanel.Dock="Right" IsVisible="{Binding !IsTwoPlotsVisible}" Background="#FFFFFF" BoxShadow="0 4 15 0 #15000000" CornerRadius="8" Padding="15" Margin="10,5,5,5" Width="300">
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Measurement Settings" FontWeight="SemiBold" FontSize="16" Foreground="#1F2937" />
                                            <ItemsControl ItemsSource="{Binding PlottedPlan.Parameters}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Vertical" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,8">
                                                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="#4B5563" HorizontalAlignment="Left" TextWrapping="Wrap" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#1F2937" HorizontalAlignment="Right" Margin="10,0,0,0" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            
                                            <Separator Margin="0,5" Background="#E5E7EB" Height="1" />
                                            <StackPanel Spacing="5">
                                                <TextBlock Text="Active Plan / File" FontWeight="SemiBold" FontSize="14" Foreground="#4B5563" />
                                                <TextBlock Text="{Binding PlottedPlan.Name}" FontWeight="Bold" Foreground="#1F2937" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding PlottedPlan.Description}" FontStyle="Italic" Foreground="#666666" TextWrapping="Wrap" FontSize="12" />
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <!-- Measurement Settings (Bottom) -->
                                <Border DockPanel.Dock="Bottom" IsVisible="{Binding IsTwoPlotsVisible}" Background="#FFFFFF" BoxShadow="0 4 15 0 #15000000" CornerRadius="8" Padding="15" Margin="0,15,0,0" MaxHeight="150">
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Measurement Settings" FontWeight="SemiBold" FontSize="16" Foreground="#1F2937" />
                                            <ItemsControl ItemsSource="{Binding PlottedPlan.Parameters}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,0,20,5">
                                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="#4B5563" />
                                                            <TextBlock Text="{Binding Value}" Foreground="#1F2937" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Separator Margin="0,5" Background="#E5E7EB" Height="1" />
                                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,20,5">
                                                <TextBlock Text="Active Plan / File:" FontWeight="SemiBold" Foreground="#4B5563" />
                                                <TextBlock Text="{Binding PlottedPlan.Name}" FontWeight="Bold" Foreground="#1F2937" />
                                                <TextBlock Text="{Binding PlottedPlan.Description}" FontStyle="Italic" Foreground="#666666" />
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <UniformGrid Rows="1">
                                    <Border IsVisible="{Binding IsLinearPlotVisible}" Margin="5" Background="#FFFFFF" BoxShadow="0 4 15 0 #15000000" CornerRadius="8">
                                        <views:CurvePlotView Title="{Binding LinearPlotTitle}"
                                                             XAxisLabel="{Binding XAxisTitle}"
                                                             YAxisLabel="{Binding YAxisTitle}"
                                                             Series="{Binding PlotSeries}"
                                                             Points="{Binding CurvePoints}"
                                                             PlotStyle="{Binding SelectedPlotStyle}"
                                                             LogarithmicX="{Binding IsViewerLogarithmicX}"
                                                             PlotAspectRatio="{Binding PlotAspectRatio}"
                                                             XMin="{Binding CustomXMin}" XMax="{Binding CustomXMax}"
                                                             YMin="{Binding CustomYMin}" YMax="{Binding CustomYMax}"
                                                             AutoFitDataX="{Binding AutoFitDataX}"
                                                             AutoFitDataY="{Binding AutoFitDataY}"
                                                             SeriesSettings="{Binding SeriesSettings}" />
                                    </Border>
                                    <Border IsVisible="{Binding IsLogPlotVisible}" Margin="5" Background="#FFFFFF" BoxShadow="0 4 15 0 #15000000" CornerRadius="8">
                                        <views:CurvePlotView Title="{Binding LogPlotTitle}"
                                                             XAxisLabel="{Binding XAxisTitle}"
                                                             YAxisLabel="{Binding YAxisTitle}"
                                                             Series="{Binding PlotSeries}"
                                                             Points="{Binding CurvePoints}"
                                                             PlotStyle="{Binding SelectedPlotStyle}"
                                                             LogarithmicY="True"
                                                             LogarithmicX="{Binding IsViewerLogarithmicX}"
                                                             PlotAspectRatio="{Binding PlotAspectRatio}"
                                                             XMin="{Binding CustomXMin}" XMax="{Binding CustomXMax}"
                                                             YMin="{Binding CustomYMin}" YMax="{Binding CustomYMax}"
                                                             AutoFitDataX="{Binding AutoFitDataX}"
                                                             AutoFitDataY="{Binding AutoFitDataY}"
                                                             SeriesSettings="{Binding SeriesSettings}" />
                                    </Border>
                                </UniformGrid>
                            </DockPanel>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Measurements">
                <Grid RowDefinitions="*, Auto" Margin="20">
                    <Grid Grid.Row="0">
                            <Grid ColumnDefinitions="55*, 45*" RowDefinitions="Auto, *" Margin="10">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Measurement Configuration" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Measurement Status &amp; Diagnostics" FontSize="18" FontWeight="SemiBold" Margin="20,0,0,0" />
                        
                        <!-- Left Column: Configuration -->
                        <ScrollViewer Grid.Row="1" Grid.Column="0" x:Name="MeasurementScrollViewer" HorizontalScrollBarVisibility="Disabled" ScrollChanged="MeasurementScrollViewer_ScrollChanged">
                        <Border Background="#FFFFFF" BorderBrush="Transparent" BorderThickness="0" CornerRadius="8" Padding="20" Margin="10,15,10,20" BoxShadow="0 4 15 0 #15000000">
                        <StackPanel Spacing="10" MaxWidth="800" IsEnabled="{Binding !IsScanningWafer}">
                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Measurement Plan:" Width="150" VerticalAlignment="Center" Margin="0,0,10,10" />
                                <ComboBox ItemsSource="{Binding MeasurementPlans}"
                                          SelectedItem="{Binding SelectedPlan}"
                                          Width="200">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </WrapPanel>

                            <WrapPanel Orientation="Horizontal" Margin="0,5,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Preset:" Width="150" VerticalAlignment="Center" Margin="0,0,10,10" />
                                <ComboBox ItemsSource="{Binding AvailablePresets}"
                                          SelectedItem="{Binding SelectedPreset}"
                                          PlaceholderText="No presets saved"
                                          Width="150" Height="32" VerticalAlignment="Center" Margin="0,0,10,10">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,10,10">
                                    <TextBox Text="{Binding NewPresetName}" PlaceholderText="Preset Name" Width="120" Height="32" VerticalContentAlignment="Center">
                                        <TextBox.Styles>
                                            <Style Selector="TextBox.invalid /template/ Border#PART_BorderElement">
                                                <Setter Property="BorderBrush" Value="#EF4444"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </Style>
                                        </TextBox.Styles>
                                        <Classes.invalid>
                                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                                <Binding Path="IsPresetNameInvalid" />
                                            </MultiBinding>
                                        </Classes.invalid>
                                    </TextBox>
                                </StackPanel>
                                <Button Content="Save" Command="{Binding SavePresetCommand}" Classes="Primary" Height="32" VerticalContentAlignment="Center" VerticalAlignment="Center" Margin="0,0,10,10" />
                                <Button Content="Delete" Command="{Binding DeletePresetCommand}" Classes="Danger" Height="32" VerticalContentAlignment="Center" IsEnabled="{Binding SelectedPreset, Converter={x:Static ObjectConverters.IsNotNull}}" VerticalAlignment="Center" Margin="0,0,10,10" />
                            </WrapPanel>
                            
                            <!-- Overwrite Confirmation popup inline -->
                            <Border Background="#FEE2E2" BorderBrush="#EF4444" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,5,0,0" IsVisible="{Binding IsOverwriteWarningVisible}">
                                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Fill="#EF4444" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBlock Text="Preset already exists. Overwrite?" Foreground="#B91C1C" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,5"/>
                                    <Button Content="Yes" Command="{Binding ConfirmSavePresetCommand}" Classes="Primary" Padding="10,3" Margin="0,0,10,5" />
                                    <Button Content="No" Command="{Binding CancelSavePresetCommand}" Classes="Secondary" Padding="10,3" Margin="0,0,0,5" />
                                </WrapPanel>
                            </Border>

                            <!-- Delete Confirmation popup inline -->
                            <Border Background="#FEE2E2" BorderBrush="#EF4444" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,5,0,0" IsVisible="{Binding IsDeleteWarningVisible}">
                                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Fill="#EF4444" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                    <TextBlock Text="Are you sure you want to delete this preset?" Foreground="#B91C1C" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,5" />
                                    <Button Content="Yes" Command="{Binding ConfirmDeletePresetCommand}" Classes="Danger" Padding="10,3" Margin="0,0,10,5" />
                                    <Button Content="No" Command="{Binding CancelDeletePresetCommand}" Classes="Secondary" Padding="10,3" Margin="0,0,0,5" />
                                </WrapPanel>
                            </Border>

                            <Separator Margin="0,15,0,15" Background="#E5E7EB" Height="1" />

                            <TextBlock Text="{Binding SelectedPlan.Description}" 
                                       TextWrapping="Wrap" 
                                       FontStyle="Italic" 
                                       Opacity="0.7" 
                                       Margin="0,5,0,15" />

                            <ItemsControl ItemsSource="{Binding SelectedPlanSections}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ParameterSection">
                                        <StackPanel Spacing="5" Margin="0,0,20,15" Width="370">
                                            <!-- Section Header -->
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="11" 
                                                       FontWeight="Bold" 
                                                       Foreground="#777777" 
                                                       Margin="0,5,0,5" 
                                                       IsVisible="{Binding HasName}" />
                                            
                                            <!-- Parameters in this Section -->
                                            <ItemsControl ItemsSource="{Binding Parameters}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:MeasurementParameter">
                                                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10" ToolTip.Tip="{Binding Tooltip}">
                                                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                            <ContentControl Grid.Column="1" Content="{Binding}" VerticalAlignment="Center">
                                                                <ContentControl.ContentTemplate>
                                                                    <views:ParameterTemplateSelector>
                                                                        <views:ParameterTemplateSelector.TextTemplate>
                                                                            <DataTemplate x:DataType="models:MeasurementParameter">
                                                                                <Grid Width="150" ColumnDefinitions="*, Auto" Background="Transparent" 
                                                                                      ToolTip.Tip="{Binding LinkTooltip}"
                                                                                      PointerPressed="ParameterGrid_PointerPressed">
                                                                                    <views:ParameterTextBox Grid.Column="0" Text="{Binding Value, Mode=TwoWay}" HorizontalAlignment="Stretch" IsEnabled="{Binding !IsLinked}" />
                                                                                    <Button Grid.Column="1" 
                                                                                            Classes.is-linked="{Binding IsLinked}"
                                                                                                  IsVisible="{Binding IsLinkable}" 
                                                                                                  Click="ToggleParameterLink_Click"
                                                                                                  VerticalAlignment="Center"
                                                                                                  VerticalContentAlignment="Center"
                                                                                                  HorizontalContentAlignment="Center"
                                                                                                  Width="26" Height="26"
                                                                                                  Margin="5,0,0,0"
                                                                                                  Padding="0"
                                                                                                  Background="Transparent"
                                                                                                  BorderThickness="0"
                                                                                                  CornerRadius="4">
                                                                                        <Button.Styles>
                                                                                            <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                                                                <Setter Property="Background" Value="#E5E7EB"/>
                                                                                            </Style>
                                                                                            <Style Selector="Button Path">
                                                                                                <Setter Property="Fill" Value="#9CA3AF"/>
                                                                                            </Style>
                                                                                            <Style Selector="Button.is-linked Path">
                                                                                                <Setter Property="Fill" Value="#111827"/>
                                                                                            </Style>
                                                                                        </Button.Styles>
                                                                                        <Path Data="M3.9,12C3.9,10.29 5.29,8.9 7,8.9H11V7H7C4.24,7 2,9.24 2,12C2,14.76 4.24,17 7,17H11V15.1H7C5.29,15.1 3.9,13.71 3.9,12ZM8,13H16V11H8V13ZM17,7H13V8.9H17C18.71,8.9 20.1,10.29 20.1,12C20.1,13.71 18.71,15.1 17,15.1H13V17H17C19.76,17 22,14.76 22,12C22,9.24 19.76,7 17,7Z" 
                                                                                              Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                                                    </Button>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </views:ParameterTemplateSelector.TextTemplate>
                                                                        <views:ParameterTemplateSelector.CheckboxTemplate>
                                                                            <DataTemplate x:DataType="models:MeasurementParameter">
                                                                                <CheckBox IsChecked="{Binding Value, Mode=TwoWay}" />
                                                                            </DataTemplate>
                                                                        </views:ParameterTemplateSelector.CheckboxTemplate>
                                                                        <views:ParameterTemplateSelector.DropdownTemplate>
                                                                            <DataTemplate x:DataType="models:MeasurementParameter">
                                                                                <ComboBox ItemsSource="{Binding Options}" 
                                                                                          SelectedItem="{Binding Value, Mode=TwoWay}" 
                                                                                          Width="200" />
                                                                            </DataTemplate>
                                                                        </views:ParameterTemplateSelector.DropdownTemplate>
                                                                    </views:ParameterTemplateSelector>
                                                                </ContentControl.ContentTemplate>
                                                            </ContentControl>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <CheckBox Content="Switch to Viewer tab automatically"
                                      IsChecked="{Binding AutoSwitchToViewer}"
                                      Margin="0,10,0,0" />

                            <CheckBox Content="Automatically save measurements"
                                      IsChecked="{Binding AutoSaveMeasurements}"
                                      Margin="0,5,0,0" />
                                      
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,20,0,0">
                                <Button Content="Run Measurement" 
                                        Command="{Binding RunMeasurementCommand}" 
                                        IsEnabled="{Binding !IsMeasuring}"
                                        Classes="Primary" 
                                        Width="180" />

                                <Button Content="Export to CSV" 
                                        Click="ExportCsvButton_Click"
                                        IsEnabled="{Binding HasCurvePoints}"
                                        Classes="Secondary" 
                                        Width="150" />
                            </StackPanel>
                        </StackPanel>
                        </Border>
                        </ScrollViewer>

                        <!-- Right Column: Status -->
                        <Grid Grid.Row="1" Grid.Column="1" Margin="20,15,10,20" RowDefinitions="Auto, *">
                            <Border Grid.Row="0" CornerRadius="8" BoxShadow="0 4 15 0 #15000000" Margin="0,0,0,15" Background="#FFFFFF" BorderBrush="Transparent" BorderThickness="0">
                                <Expander Header="Measurement Status &amp; Diagnostics" IsExpanded="False" HorizontalAlignment="Stretch" CornerRadius="8" Background="Transparent" BorderThickness="0" BorderBrush="Transparent">
                                    <Expander.Styles>
                                        <Style Selector="Expander /template/ ToggleButton#ExpanderHeader">
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Setter Property="Background" Value="Transparent" />
                                        </Style>
                                    </Expander.Styles>
                                    <StackPanel Spacing="10" Margin="15,0,15,15">
                                        <Border BorderBrush="Transparent" BorderThickness="0" CornerRadius="4" Padding="15" Background="#F9F9F9" MinWidth="450" MinHeight="80">
                                            <TextBlock Text="{Binding MeasurementStatus}" 
                                                       Foreground="#333333"
                                                       FontFamily="Courier New" 
                                                       FontSize="12" 
                                                       TextWrapping="Wrap" />
                                        </Border>

                                        <StackPanel Spacing="5" IsVisible="{Binding IsMeasuringSweep}">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <TextBlock Text="Measurement Progress" FontSize="11" FontWeight="SemiBold" Foreground="#666666" />
                                                <TextBlock Grid.Column="1" Text="{Binding MeasurementProgressText}" FontSize="11" FontWeight="SemiBold" Foreground="#333333" />
                                            </Grid>
                                            <ProgressBar Minimum="0" 
                                                         Maximum="100" 
                                                         Value="{Binding MeasurementProgress}" 
                                                         IsIndeterminate="{Binding IsProgressIndeterminate}" 
                                                         Height="8" 
                                                         CornerRadius="4"
                                                         Foreground="#3B82F6"
                                                         Background="#E0E0E0" />
                                        </StackPanel>

                                        <TextBlock Text="{Binding WarningMessage}" 
                                                   Foreground="#E65100" 
                                                   TextWrapping="Wrap" 
                                                   HorizontalAlignment="Stretch"
                                                   IsVisible="{Binding HasWarningMessage}" />

                                        <TextBlock Text="{Binding ErrorMessage}" 
                                                   Foreground="#D32F2F" 
                                                   TextWrapping="Wrap" 
                                                   HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </Expander>
                            </Border>

                            <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="Transparent" BorderThickness="0" CornerRadius="8" Padding="20" BoxShadow="0 4 15 0 #15000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <Grid RowDefinitions="*, Auto">
                                    <views:CurvePlotView Grid.Row="0" Title="Live Measurement Preview"
                                                         XAxisLabel="{Binding XAxisTitle}"
                                                         YAxisLabel="{Binding YAxisTitle}"
                                                         Series="{Binding PlotSeries}"
                                                         Points="{Binding CurvePoints}"
                                                         PlotStyle="{Binding SelectedPlotStyle}"
                                                         LogarithmicY="{Binding IsMeasurementLogarithmic}"
                                                         LogarithmicX="{Binding IsMeasurementLogarithmicX}"
                                                         PlotAspectRatio="{Binding PlotAspectRatio}"
                                                     SeriesSettings="{Binding SeriesSettings}" />
                                    
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="20" Margin="0,15,0,0" HorizontalAlignment="Center">
                                        <CheckBox Content="Logarithmic X-Axis" IsChecked="{Binding IsMeasurementLogarithmicX}" />
                                        <CheckBox Content="Logarithmic Y-Axis" IsChecked="{Binding IsMeasurementLogarithmic}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                            </Grid>

                        <!-- Scroll Indicator -->
                        <Border x:Name="MeasurementScrollIndicator" 
                                VerticalAlignment="Bottom" 
                                Height="30" 
                                IsHitTestVisible="False"
                                Opacity="0">
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                                </Transitions>
                            </Border.Transitions>
                            <Path Data="M0,0 L6,6 L12,0" 
                                  Stroke="#888888" 
                                  StrokeThickness="2" 
                                  Fill="Transparent" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Bottom" 
                                  Margin="0,0,0,10"/>
                        </Border>
                    </Grid>
            </Grid>
        </TabItem>

            <TabItem Header="Wafermap">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="20" MinWidth="400" MinHeight="650">
                    <Grid ColumnDefinitions="40*,30,60*">
                        <!-- Left Container: Settings & Log & Sub-cells -->
                        <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*">
                            <!-- Top: Settings and Buttons -->
                            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="Transparent" BorderThickness="0" CornerRadius="8" Padding="20" Margin="10,10,10,5" BoxShadow="0 4 15 0 #15000000" VerticalAlignment="Top">
                                <StackPanel Spacing="20">
                                    <TextBlock Text="Automatic Wafer Scan" FontSize="20" FontWeight="Bold" Margin="0,0,0,0" TextWrapping="Wrap" />
                                    <TextBlock Text="Note: The automatic wafer scan will execute the measurement plan currently selected in the 'Measurements' tab at each target contact." FontStyle="Italic" TextWrapping="Wrap" Foreground="#666666" Margin="0,0,0,10" />

                                    <StackPanel Spacing="15" IsEnabled="{Binding !IsScanningWafer}">
                                        <!-- Scan Presets -->
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Scan Presets:" FontSize="14" FontWeight="SemiBold" />
                                            <Grid ColumnDefinitions="*,Auto">
                                                <ComboBox Grid.Column="0" ItemsSource="{Binding WaferScanPresetNames}" SelectedItem="{Binding SelectedWaferScanPreset}" HorizontalAlignment="Stretch" Margin="0,0,10,0" PlaceholderText="Select a preset..." />
                                                <Button Grid.Column="1" Content="Delete" Command="{Binding DeleteWaferScanPresetCommand}" Classes="Danger" Width="80" Height="36" />
                                            </Grid>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0" Text="{Binding NewWaferScanPresetName}" PlaceholderText="Preset Name" HorizontalAlignment="Stretch" Margin="0,0,10,0" Height="36" VerticalContentAlignment="Center" />
                                                <Button Grid.Column="1" Content="Save" Command="{Binding SaveWaferScanPresetCommand}" Classes="Primary" Width="80" Height="36" />
                                            </Grid>
                                        </StackPanel>

                                        <!-- Movement Delay -->
                                        <StackPanel Spacing="5">
                                            <TextBlock Text="Movement Delay (ms):" FontSize="14" FontWeight="SemiBold" />
                                            <TextBox Text="{Binding WaferScanDelayMs}" Width="120" HorizontalAlignment="Left" Height="32" VerticalContentAlignment="Center" />
                                        </StackPanel>

                                        <!-- Buttons -->
                                        <StackPanel Spacing="10" Margin="0,10,0,0">
                                            <Button Content="Start Wafer Scan" Command="{Binding ScanWaferCommand}" Classes="Primary" HorizontalAlignment="Stretch" Height="36" />
                                            <Button Content="Stop Scan" Command="{Binding RequestStopScanCommand}" Classes="Danger" HorizontalAlignment="Stretch" Height="36" />
                                            <Button Content="Move to Start Point" Command="{Binding GoToScanStartCommand}" Classes="Secondary" HorizontalAlignment="Stretch" Height="36" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Middle: Sub-cells and Contacts -->
                            <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="Transparent" BorderThickness="0" CornerRadius="8" Padding="20" Margin="10,5,10,5" BoxShadow="0 4 15 0 #15000000" VerticalAlignment="Top">
                                <Grid ColumnDefinitions="*,15,*" IsEnabled="{Binding !IsScanningWafer}">
                                    <!-- Left: 5x5 Sub-cells Grid -->
                                    <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*">
                                        <TextBlock Grid.Row="0" Text="Global Sub-cells (5x5)" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0" TextWrapping="Wrap" />
                                        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,15,0,15">
                                            <Button Content="Select All" Command="{Binding SelectAllSubCellsCommand}" Classes="Secondary" Padding="10,5" Margin="0,0,10,0" />
                                            <Button Content="Deselect All" Command="{Binding DeselectAllSubCellsCommand}" Classes="Secondary" Padding="10,5" Margin="0,0,10,0" />
                                        </WrapPanel>
                                        
                                        <Viewbox Grid.Row="2" Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Background="#F3F4F6" Padding="10" CornerRadius="8">
                                                <ItemsControl x:Name="SubCellsItemsControl" ItemsSource="{Binding SubCells}">
                                                    <ItemsControl.Styles>
                                                        <Style Selector="ToggleButton">
                                                            <Setter Property="Background" Value="#FFCDD2" />
                                                        </Style>
                                                        <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                                                            <Setter Property="Background" Value="#C8E6C9" />
                                                        </Style>
                                                        <Style Selector="ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                            <Setter Property="Background" Value="#EF9A9A" />
                                                        </Style>
                                                        <Style Selector="ToggleButton:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                            <Setter Property="Background" Value="#A5D6A7" />
                                                        </Style>
                                                    </ItemsControl.Styles>
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Columns="5" Rows="5" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SubCellViewModel">
                                                            <Border Width="44" Height="44" Margin="3">
                                                                <ToggleButton IsChecked="{Binding IsSelected}" 
                                                                              IsVisible="{Binding IsValid}" 
                                                                              HorizontalAlignment="Stretch" 
                                                                              VerticalAlignment="Stretch"
                                                                              CornerRadius="4"
                                                                              ToolTip.Tip="{Binding Id}"
                                                                              Padding="0">
                                                                    <TextBlock Text="{Binding Id}" FontSize="12" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </ToggleButton>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </Viewbox>
                                    </Grid>

                                    <!-- Right: Target Contacts (3x2) -->
                                    <Grid Grid.Column="2" RowDefinitions="Auto,Auto,*">
                                        <TextBlock Grid.Row="0" Text="Target Contacts (1-6)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,0" TextWrapping="Wrap" />
                                        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,15,0,15">
                                            <Button Content="Select All" Command="{Binding SelectAllContactsCommand}" Classes="Secondary" Padding="10,5" Margin="0,0,10,0" />
                                            <Button Content="Deselect All" Command="{Binding DeselectAllContactsCommand}" Classes="Secondary" Padding="10,5" Margin="0,0,10,0" />
                                        </WrapPanel>
                                        
                                        <Viewbox Grid.Row="2" Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Background="#F3F4F6" Padding="10" CornerRadius="8">
                                                <ItemsControl ItemsSource="{Binding Contacts}">
                                                    <ItemsControl.Styles>
                                                        <Style Selector="ToggleButton">
                                                            <Setter Property="Background" Value="#FFCDD2" />
                                                        </Style>
                                                        <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                                                            <Setter Property="Background" Value="#C8E6C9" />
                                                        </Style>
                                                        <Style Selector="ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                            <Setter Property="Background" Value="#EF9A9A" />
                                                        </Style>
                                                        <Style Selector="ToggleButton:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                            <Setter Property="Background" Value="#A5D6A7" />
                                                        </Style>
                                                    </ItemsControl.Styles>
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Columns="3" Rows="2" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:ContactViewModel">
                                                            <Border Width="44" Height="44" Margin="3">
                                                                <ToggleButton IsChecked="{Binding IsSelected}" 
                                                                              HorizontalAlignment="Stretch" 
                                                                              VerticalAlignment="Stretch"
                                                                              CornerRadius="4"
                                                                              ToolTip.Tip="{Binding Id}"
                                                                              Padding="0">
                                                                    <TextBlock Text="{Binding Id}" FontSize="12" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </ToggleButton>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </Viewbox>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Bottom: Log -->
                            <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="Transparent" BorderThickness="0" CornerRadius="8" Padding="20" Margin="10,5,10,10" BoxShadow="0 4 15 0 #15000000" VerticalAlignment="Stretch">
                                <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="0,0,0,0">
                                    <ProgressBar Grid.Row="0" Value="{Binding WaferScanProgress}" Minimum="0" Maximum="100" Height="20" Foreground="Black" HorizontalAlignment="Stretch" Margin="0,0,0,10" IsVisible="{Binding IsScanningWafer}" />
                                    <TextBlock Grid.Row="1" Text="Status / Log" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <ScrollViewer Grid.Row="2" Background="#F9FAFB" Padding="10" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10" MinHeight="100" IsVisible="{Binding HasWaferScanLog}">
                                        <TextBlock Text="{Binding WaferScanLog}" FontFamily="Consolas, monospace" FontSize="12" Foreground="#374151" TextWrapping="Wrap" />
                                    </ScrollViewer>
                                    <WrapPanel Grid.Row="3" Orientation="Horizontal">
                                        <TextBlock Text="{Binding WaferScanCountText}" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0" />
                                        <TextBlock Text="{Binding WaferScanEstimatedFinish}" Foreground="#666666" VerticalAlignment="Center" />
                                    </WrapPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Right Container: Target Cells (16x16) -->
                        <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="Transparent" BorderThickness="0" CornerRadius="8" Padding="20" Margin="10" BoxShadow="0 4 15 0 #15000000" VerticalAlignment="Stretch">
                            <Grid RowDefinitions="Auto,Auto,*" IsEnabled="{Binding !IsScanningWafer}">
                                <TextBlock Grid.Row="0" Text="Target Cells (16x16)" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0" TextWrapping="Wrap" />
                                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,15,0,15">
                                    <Button Content="Select All" Command="{Binding SelectAllCellsCommand}" Classes="Secondary" Padding="10,5" Margin="0,0,10,0" />
                                    <Button Content="Deselect All" Command="{Binding DeselectAllCellsCommand}" Classes="Secondary" Padding="10,5" Margin="0,0,10,0" />
                                </WrapPanel>

                                <Viewbox Grid.Row="2" Stretch="Uniform" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                    <Border Background="#F3F4F6" Padding="15" CornerRadius="8">
                                        <ItemsControl x:Name="WaferCellsItemsControl" ItemsSource="{Binding WaferCells}">
                                            <ItemsControl.Styles>
                                                <Style Selector="ToggleButton">
                                                    <Setter Property="Background" Value="#FFCDD2" />
                                                </Style>
                                                <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                                                    <Setter Property="Background" Value="#C8E6C9" />
                                                </Style>
                                                <Style Selector="ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                    <Setter Property="Background" Value="#EF9A9A" />
                                                </Style>
                                                <Style Selector="ToggleButton:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                    <Setter Property="Background" Value="#A5D6A7" />
                                                </Style>
                                            </ItemsControl.Styles>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="16" Rows="16" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:WaferCellViewModel">
                                                    <Border Width="38" Height="38" Margin="1">
                                                        <ToggleButton IsChecked="{Binding IsSelected}" 
                                                                      IsVisible="{Binding IsValid}" 
                                                                      HorizontalAlignment="Stretch" 
                                                                      VerticalAlignment="Stretch"
                                                                      ToolTip.Tip="{Binding Id}"
                                                                      CornerRadius="4"
                                                                      Padding="0">
                                                            <TextBlock Text="{Binding Id}" FontSize="9" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </ToggleButton>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </Viewbox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Result">
                <Grid>
                    <!-- Empty State Placeholder (No Folder Loaded) -->
                    <Border IsVisible="{Binding !IsResultFolderLoaded}"
                            Background="#F9FAFB"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="40"
                            Margin="30"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="500">
                        <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- Visual Circle / Icon Representative -->
                            <Border Width="80" Height="80" CornerRadius="40" Background="#EEF2F6" HorizontalAlignment="Center">
                                <Path Fill="#6B7280" Data="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" Width="36" Height="36" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            
                            <TextBlock Text="No wafer map folder loaded" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="#1F2937" 
                                       HorizontalAlignment="Center" 
                                       TextAlignment="Center"/>
                                       
                            <TextBlock Text="Please load a wafer scan folder with the CSV measurement results to display the wafer map visualization and I-V curves." 
                                       TextWrapping="Wrap" 
                                       FontSize="14" 
                                       Foreground="#4B5563" 
                                       HorizontalAlignment="Center" 
                                       TextAlignment="Center"
                                       LineHeight="20"/>
                            
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <Button Content="Load scan folder" 
                                        Click="LoadResultFolderButton_Click" 
                                        Classes="Primary" 
                                        Padding="20,10" 
                                        Margin="0,0,10,0"/>
                                <Button Content="Load from DB" 
                                        Click="LoadResultFromDatabaseButton_Click" 
                                        Classes="Secondary" 
                                        Padding="20,10"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Normal Result UI -->
                    <ScrollViewer IsVisible="{Binding IsResultFolderLoaded}" Margin="20" HorizontalScrollBarVisibility="Disabled">
                        <Grid RowDefinitions="Auto,*" Margin="10">
                        <!-- Top Bar / Metric Settings -->
                        <Border Grid.Row="0" Background="#FFFFFF" BoxShadow="0 4 15 0 #15000000" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <StackPanel Spacing="15">
                                <TextBlock Text="Metric Settings" FontSize="18" FontWeight="SemiBold" />
                                <WrapPanel Orientation="Horizontal">
                                    <Button Content="Load Scan Folder" Click="LoadResultFolderButton_Click" Classes="Primary" Padding="10,5" Margin="0,0,10,0" VerticalAlignment="Center" />
                                    <Button Content="Load from DB" Click="LoadResultFromDatabaseButton_Click" Classes="Secondary" Padding="10,5" Margin="0,0,20,0" VerticalAlignment="Center" />
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,0,20,0">
                                        <TextBlock Text="Visualization Metric:" VerticalAlignment="Center" FontWeight="SemiBold" />
                                        <ComboBox ItemsSource="{Binding AvailableResultMetrics}"
                                                  SelectedItem="{Binding SelectedResultMetric}"
                                                  Width="200" />
                                                  
                                        <StackPanel Orientation="Horizontal" Spacing="5" IsVisible="{Binding IsGapMetricSelected}">
                                            <TextBlock Text="Target V:" VerticalAlignment="Center" />
                                            <NumericUpDown Value="{Binding GapTargetVoltage}" 
                                                           FormatString="0.00" 
                                                           Increment="0.1" 
                                                           Width="130" 
                                                           Height="32" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="Color Low:" VerticalAlignment="Center" FontWeight="SemiBold" />
                                        <ComboBox ItemsSource="{Binding AvailableHeatmapColors}"
                                                  SelectedItem="{Binding SelectedHeatmapColorLow}"
                                                  Width="120" />
                                        <TextBlock Text="Color High:" VerticalAlignment="Center" FontWeight="SemiBold" />
                                        <ComboBox ItemsSource="{Binding AvailableHeatmapColors}"
                                                  SelectedItem="{Binding SelectedHeatmapColorHigh}"
                                                  Width="120" />
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Main 3-Column Layout -->
                        <Grid Grid.Row="1" ColumnDefinitions="5*, 2*, 5*">
                            <!-- Left: 16x16 Wafermap -->
                            <Border Grid.Column="0" Background="#FFFFFF" BoxShadow="0 4 15 0 #15000000" CornerRadius="8" Padding="20" Margin="0,0,20,0" VerticalAlignment="Top">
                                <StackPanel Spacing="10">
                                <TextBlock Text="Wafer Cells (16x16)" FontSize="16" FontWeight="SemiBold" />
                                <Viewbox Stretch="Uniform" HorizontalAlignment="Left" StretchDirection="DownOnly" MaxWidth="700">
                                    <Border Background="#F3F4F6" Padding="15" CornerRadius="8">
                                        <ItemsControl ItemsSource="{Binding ResultCells}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="16" Rows="16" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ResultCellViewModel">
                                                    <Border Width="42" Height="42" Margin="1" Background="{Binding Color}" CornerRadius="4" IsVisible="{Binding IsValid}" Classes.selected="{Binding IsSelected}">
                                                        <Border.Styles>
                                                            <Style Selector="Border.selected">
                                                                <Setter Property="BorderBrush" Value="#1F2937" />
                                                                <Setter Property="BorderThickness" Value="2" />
                                                            </Style>
                                                        </Border.Styles>
                                                        <ToolTip.Tip>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Id}" FontWeight="Bold" />
                                                                <TextBlock Text="{Binding FormattedValue}" />
                                                                <TextBlock Text="{Binding MetricLabel}" IsVisible="{Binding MetricLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" FontStyle="Italic" Foreground="Gray" />
                                                            </StackPanel>
                                                        </ToolTip.Tip>
                                                        <Grid>
                                                            <RadioButton GroupName="ResultCells" 
                                                                         IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectedResultCell, Mode=OneWayToSource, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                         Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SetSelectedResultCellCommand}"
                                                                         CommandParameter="{Binding}"
                                                                         Opacity="0"
                                                                         HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                                            <TextBlock Text="{Binding Id}" FontSize="9" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </Viewbox>
                                </StackPanel>
                            </Border>

                            <!-- Middle: 5x5 SubCells & Contacts -->
                            <Border Grid.Column="1" Background="#FFFFFF" BoxShadow="0 4 15 0 #15000000" CornerRadius="8" Padding="20" Margin="0,0,20,0" VerticalAlignment="Top">
                                <StackPanel Spacing="20">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Sub-Cells (5x5)" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock Text="Select a cell on the left first." IsVisible="{Binding SelectedResultCell, Converter={x:Static ObjectConverters.IsNull}}" FontStyle="Italic" Foreground="Gray" />
                                    
                                    <Viewbox Stretch="Uniform" HorizontalAlignment="Left" StretchDirection="DownOnly" MaxWidth="350" IsVisible="{Binding SelectedResultCell, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <Border Background="#F3F4F6" Padding="10" CornerRadius="8">
                                            <ItemsControl ItemsSource="{Binding SelectedResultCell.SubCells}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="5" Rows="5" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:ResultSubCellViewModel">
                                                        <Border Width="65" Height="65" Margin="3" Background="{Binding Color}" CornerRadius="4" IsVisible="{Binding IsValid}" Classes.selected="{Binding IsSelected}">
                                                            <Border.Styles>
                                                                <Style Selector="Border.selected">
                                                                    <Setter Property="BorderBrush" Value="#1F2937" />
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                </Style>
                                                            </Border.Styles>
                                                            <ToolTip.Tip>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Id}" FontWeight="Bold" />
                                                                    <TextBlock Text="{Binding FormattedValue}" />
                                                                    <TextBlock Text="{Binding MetricLabel}" IsVisible="{Binding MetricLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" FontStyle="Italic" Foreground="Gray" />
                                                                </StackPanel>
                                                            </ToolTip.Tip>
                                                            <Grid>
                                                                <RadioButton GroupName="ResultSubCells"
                                                                             Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SetSelectedResultSubCellCommand}"
                                                                             CommandParameter="{Binding}"
                                                                             Opacity="0"
                                                                             HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                                                <TextBlock Text="{Binding Id}" FontSize="14" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </Viewbox>
                                </StackPanel>

                                <StackPanel Spacing="10" IsVisible="{Binding SelectedResultSubCell, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <TextBlock Text="Contacts" FontSize="16" FontWeight="SemiBold" />
                                    <ListBox ItemsSource="{Binding SelectedResultSubCell.Contacts}"
                                             SelectedItem="{Binding SelectedResultContact}"
                                             Background="Transparent"
                                             BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ResultContactViewModel">
                                                <Border Background="{Binding Color}" CornerRadius="4" Padding="10,5" Margin="0,2">
                                                    <ToolTip.Tip>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" />
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectedResultMetric}" FontWeight="SemiBold"/>
                                                                <TextBlock Text=":"/>
                                                                <TextBlock Text="{Binding FormattedValue}" />
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding MetricLabel}" IsVisible="{Binding MetricLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" FontStyle="Italic" Foreground="Gray" />
                                                        </StackPanel>
                                                    </ToolTip.Tip>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="#1F2937" />
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Right: CurvePlotView -->
                            <Border Grid.Column="2" Background="#FFFFFF" BoxShadow="0 4 15 0 #15000000" CornerRadius="8" Padding="20" VerticalAlignment="Top">
                                <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <TextBlock Text="I-V Curve" FontSize="16" FontWeight="SemiBold" />
                                    <Border Background="#EEF2F6" CornerRadius="4" Padding="8,4" IsVisible="{Binding SelectedResultContact, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <TextBlock FontWeight="Bold" Foreground="#1F2937">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}Cell: {0} | Sub: {1} | {2}">
                                                    <Binding Path="SelectedResultCell.Id" FallbackValue="-" />
                                                    <Binding Path="SelectedResultSubCell.Id" FallbackValue="-" />
                                                    <Binding Path="SelectedResultContact.DisplayName" FallbackValue="-" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Select a contact to view its curve." IsVisible="{Binding SelectedResultContact, Converter={x:Static ObjectConverters.IsNull}}" FontStyle="Italic" Foreground="Gray" />
                                
                                <ScrollViewer IsVisible="{Binding SelectedResultContact, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <StackPanel Spacing="16">
                                        <views:CurvePlotView Title="{Binding SelectedResultContact.DisplayName}"
                                                             XAxisLabel="Voltage (V)"
                                                             YAxisLabel="Current (A)"
                                                             Points="{Binding SelectedResultContact.CurveData}"
                                                             Height="400" />

                                        <views:CurvePlotView Title="I/U Curve - Logarithmic"
                                                             XAxisLabel="Voltage (V)"
                                                             YAxisLabel="Current (A)"
                                                             Points="{Binding SelectedResultContact.CurveData}"
                                                             LogarithmicY="True"
                                                             Height="400" />
                                    </StackPanel>
                                </ScrollViewer>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </Grid>
                </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
        </DockPanel>

        <!-- Cancel Prompt Overlay -->
        <Grid Background="#80000000" IsVisible="{Binding IsCancelPromptVisible}" ZIndex="100">
            <Border Background="White" CornerRadius="8" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400" BorderBrush="LightGray" BorderThickness="1">
                <StackPanel Spacing="20">
                    <TextBlock Text="Cancel Wafer Scan?" FontSize="20" FontWeight="Bold" Foreground="#D32F2F" />
                    <TextBlock Text="Are you sure you want to stop the scan? All further measurements will be aborted." TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right">
                        <Button Content="No, Continue" Command="{Binding CancelStopRequestCommand}" Classes="Secondary" />
                        <Button Content="Yes, Stop Scan" Command="{Binding ConfirmStopScanCommand}" Classes="Danger" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Error Popup Overlay -->
        <Grid Background="#80000000" IsVisible="{Binding IsErrorPopupVisible}" ZIndex="100">
            <Border Background="White" CornerRadius="8" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400" BorderBrush="LightGray" BorderThickness="1">
                <StackPanel Spacing="20">
                    <TextBlock Text="Scan Error" FontSize="20" FontWeight="Bold" Foreground="#D32F2F" />
                    <TextBlock Text="{Binding PopupErrorMessage}" TextWrapping="Wrap" />
                    <Button Content="OK" Command="{Binding CloseErrorPopupCommand}" Classes="Secondary" HorizontalAlignment="Right" Width="100" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Alignment Warning Overlay -->
        <Grid Background="#80000000" IsVisible="{Binding IsAlignmentWarningVisible}" ZIndex="100">
            <Border Background="White" CornerRadius="8" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400" BorderBrush="LightGray" BorderThickness="1">
                <StackPanel Spacing="20">
                    <TextBlock Text="Alignment Confirmation" FontSize="20" FontWeight="Bold" Foreground="#1F2937" />
                    <TextBlock Text="Have you correctly aligned the wafer to cell 0104 and set the home position?" TextWrapping="Wrap" />
                    
                    <Border Background="#F3F4F6" CornerRadius="6" Padding="10,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Path Fill="#4B5563" Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="Plan to execute:" FontWeight="SemiBold" Foreground="#4B5563" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedPlan.Name}" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CancelAlignmentWarningCommand}" Classes="Secondary" />
                        <Button Content="Yes, Start Scan" Command="{Binding ProceedWithScanCommand}" Classes="Primary" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Centered Toast Notification -->
        <Border x:Name="ToastBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,50"
                Background="#1E1E1E"
                CornerRadius="20"
                Padding="16,10"
                Opacity="0"
                IsVisible="False"
                ZIndex="1000">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25"/>
                </Transitions>
            </Border.Transitions>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                      Fill="#EF4444" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                <TextBlock x:Name="ToastTextBlock" Foreground="White" FontSize="13" VerticalAlignment="Center" MaxWidth="300" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>