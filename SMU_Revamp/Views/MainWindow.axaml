<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SMU_Revamp.ViewModels"
        xmlns:views="using:SMU_Revamp.Views"
        xmlns:models="using:SMU_Revamp.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SMU_Revamp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/tf_logo_rgb_en.ico"
        Title="Wafer Measurement Tool"
        WindowState="Maximized">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
        to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="Background" Value="Black" />
        </Style>
    </Window.Styles>

    <Grid>
        <DockPanel>
        <!-- Header with Settings and Debug Buttons -->
        <Grid DockPanel.Dock="Top" Margin="20,10,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Profile:" VerticalAlignment="Center" FontWeight="SemiBold" />
                <TextBox Text="{Binding Settings.Profile}" Width="150" />
                
                <TextBlock Text="Sample:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="10,0,0,0" />
                <TextBox Text="{Binding Settings.SampleName}" Width="150" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button Content="Configuration" Click="DebugButton_Click" Classes="Secondary" Padding="10,5" />
                <Button Content="Defaults" Click="DefaultsButton_Click" Classes="Secondary" Padding="10,5" />
                <Button Content="Settings" Click="SettingsButton_Click" Classes="Primary" Padding="10,5" />
            </StackPanel>
        </Grid>

        <!-- Global Progress Bar Panel (Visible during active measurement or wafer scan) -->
        <Border DockPanel.Dock="Top" 
                IsVisible="{Binding IsGlobalProgressVisible}"
                Background="#EEF2F6"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1"
                Padding="20,12"
                Margin="20,10,20,0"
                CornerRadius="8">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Path Fill="#4B5563" Data="M19 8l-4 4h3c0 3.31-2.69 6-6 6-1.01 0-1.97-.25-2.8-.7l-1.46 1.46C8.97 19.54 10.43 20 12 20c4.42 0 8-3.58 8-8h3l-4-4zM6 12c0-3.31 2.69-6 6-6 1.01 0 1.97.25 2.8.7l1.46-1.46C15.03 4.46 13.57 4 12 4c-4.42 0-8 3.58-8 8H1l4 4 4-4H6z" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <TextBlock Text="{Binding GlobalProgressTitle}" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                    <TextBlock Text="—" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding GlobalProgressStatusText}" Foreground="#4B5563" VerticalAlignment="Center"/>
                </StackPanel>
                
                <ProgressBar Grid.Column="1" 
                             Minimum="0" 
                             Maximum="100" 
                             Value="{Binding GlobalProgressValue}" 
                             IsIndeterminate="{Binding IsGlobalProgressIndeterminate}" 
                             Height="10" 
                             CornerRadius="5"
                             Foreground="#10B981"
                             Background="#D1D5DB"
                             Margin="20,0"
                             VerticalAlignment="Center"/>
                             
                <Button Grid.Column="2" 
                        Content="Stop Scan" 
                        Command="{Binding RequestStopScanCommand}" 
                        IsVisible="{Binding IsScanningWafer}"
                        Classes="Danger" 
                        Padding="15,6"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main Content with Tabs -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}" Margin="20" Padding="20">
            <TabItem Header="Viewer">
                <Grid>
                    <!-- Empty State Placeholder (No Data Loaded) -->
                    <Border IsVisible="{Binding !IsPlottedPlanLoaded}"
                            Background="#F9FAFB"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="40"
                            Margin="30"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="500">
                        <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- Visual Circle / Icon Representative (Chart Icon) -->
                            <Border Width="80" Height="80" CornerRadius="40" Background="#EEF2F6" HorizontalAlignment="Center">
                                <Path Fill="#6B7280" Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" Width="36" Height="36" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            
                            <TextBlock Text="No measurement data loaded" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="#1F2937" 
                                       HorizontalAlignment="Center" 
                                       TextAlignment="Center"/>
                                       
                            <TextBlock Text="Please execute a measurement in the Measurements tab or import a CSV/TSV measurement file to view the plots." 
                                       TextWrapping="Wrap" 
                                       FontSize="14" 
                                       Foreground="#4B5563" 
                                       HorizontalAlignment="Center" 
                                       TextAlignment="Center"
                                       LineHeight="20"/>
                            
                            <Button Content="Import File" 
                                    Click="ImportFileButton_Click" 
                                    Classes="Primary" 
                                    Padding="20,10" 
                                    HorizontalAlignment="Center" 
                                    Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Normal Viewer UI -->
                    <Grid IsVisible="{Binding IsPlottedPlanLoaded}" Margin="20" RowDefinitions="Auto, *">
                        <!-- Top Control Bar -->
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                                <!-- Left: Plan Information (Responsive Grid) -->
                                <Grid Grid.Column="0" ColumnDefinitions="Auto, *" VerticalAlignment="Center" Margin="0,0,20,0">
                                    <Border Grid.Column="0" Background="#EEF2F6" CornerRadius="6" Padding="8,4" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Path Fill="#4B5563" Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                                            <TextBlock Text="Active Plan:" FontWeight="SemiBold" Foreground="#4B5563" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding PlottedPlan.Name}" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding PlottedPlan.Description}" FontStyle="Italic" Foreground="#666666" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>

                                <!-- Right: Dropdown for Plot View and Export button -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="Plot View:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#4B5563"/>
                                        <ComboBox ItemsSource="{Binding AvailablePlotViews}"
                                                  SelectedItem="{Binding SelectedPlotView}"
                                                  Width="150" Height="32" VerticalContentAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="Plot Style:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#4B5563"/>
                                        <ComboBox ItemsSource="{Binding AvailablePlotStyles}"
                                                  SelectedItem="{Binding SelectedPlotStyleString}"
                                                  Width="150" Height="32" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <Button Content="Import File" 
                                            Click="ImportFileButton_Click"
                                            Classes="Primary" 
                                            Height="32"
                                            Padding="15,0"
                                            VerticalContentAlignment="Center" />

                                    <Button Content="Export Data to CSV" 
                                            Click="ExportCsvButton_Click"
                                            IsEnabled="{Binding HasCurvePoints}"
                                            Classes="Secondary" 
                                            Height="32"
                                            Padding="15,0"
                                            VerticalContentAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <UniformGrid Grid.Row="1" Rows="1">
                                <Border IsVisible="{Binding IsLinearPlotVisible}" Margin="5">
                                    <views:CurvePlotView Title="{Binding LinearPlotTitle}"
                                                         XAxisLabel="{Binding XAxisTitle}"
                                                         YAxisLabel="{Binding YAxisTitle}"
                                                         Series="{Binding PlotSeries}"
                                                         Points="{Binding CurvePoints}"
                                                         PlotStyle="{Binding SelectedPlotStyle}" />
                                </Border>
                                <Border IsVisible="{Binding IsLogPlotVisible}" Margin="5">
                                    <views:CurvePlotView Title="{Binding LogPlotTitle}"
                                                         XAxisLabel="{Binding XAxisTitle}"
                                                         YAxisLabel="{Binding YAxisTitle}"
                                                         Series="{Binding PlotSeries}"
                                                         Points="{Binding CurvePoints}"
                                                         PlotStyle="{Binding SelectedPlotStyle}"
                                                         LogarithmicY="True" />
                                </Border>
                            </UniformGrid>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Measurements">
                <ScrollViewer Margin="20" HorizontalScrollBarVisibility="Disabled">
                    <Grid ColumnDefinitions="1.4*, *" RowDefinitions="Auto, *" Margin="10">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Measurement Configuration" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Measurement Status &amp; Diagnostics" FontSize="18" FontWeight="SemiBold" Margin="20,0,0,0" />
                        
                        <!-- Left Column: Configuration -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="10" Margin="10,15,10,0" MaxWidth="800" IsEnabled="{Binding !IsScanningWafer}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Measurement Plan:" Width="150" VerticalAlignment="Center" />
                                <ComboBox ItemsSource="{Binding MeasurementPlans}"
                                          SelectedItem="{Binding SelectedPlan}"
                                          Width="200">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <TextBlock Text="{Binding SelectedPlan.Description}" 
                                       TextWrapping="Wrap" 
                                       FontStyle="Italic" 
                                       Opacity="0.7" 
                                       Margin="0,5,0,15" />

                            <ItemsControl ItemsSource="{Binding SelectedPlanSections}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ParameterSection">
                                        <StackPanel Spacing="5" Margin="0,0,20,15" Width="370">
                                            <!-- Section Header -->
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="11" 
                                                       FontWeight="Bold" 
                                                       Foreground="#777777" 
                                                       Margin="0,5,0,5" 
                                                       IsVisible="{Binding HasName}" />
                                            
                                            <!-- Parameters in this Section -->
                                            <ItemsControl ItemsSource="{Binding Parameters}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:MeasurementParameter">
                                                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10" ToolTip.Tip="{Binding Tooltip}">
                                                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                            <ContentControl Grid.Column="1" Content="{Binding}" VerticalAlignment="Center">
                                                                <ContentControl.ContentTemplate>
                                                                    <views:ParameterTemplateSelector>
                                                                        <views:ParameterTemplateSelector.TextTemplate>
                                                                            <DataTemplate x:DataType="models:MeasurementParameter">
                                                                                <views:ParameterTextBox Text="{Binding Value, Mode=TwoWay}" Width="150" />
                                                                            </DataTemplate>
                                                                        </views:ParameterTemplateSelector.TextTemplate>
                                                                        <views:ParameterTemplateSelector.CheckboxTemplate>
                                                                            <DataTemplate x:DataType="models:MeasurementParameter">
                                                                                <CheckBox IsChecked="{Binding Value, Mode=TwoWay}" />
                                                                            </DataTemplate>
                                                                        </views:ParameterTemplateSelector.CheckboxTemplate>
                                                                        <views:ParameterTemplateSelector.DropdownTemplate>
                                                                            <DataTemplate x:DataType="models:MeasurementParameter">
                                                                                <ComboBox ItemsSource="{Binding Options}" 
                                                                                          SelectedItem="{Binding Value, Mode=TwoWay}" 
                                                                                          Width="200" />
                                                                            </DataTemplate>
                                                                        </views:ParameterTemplateSelector.DropdownTemplate>
                                                                    </views:ParameterTemplateSelector>
                                                                </ContentControl.ContentTemplate>
                                                            </ContentControl>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <CheckBox Content="Switch to Viewer tab automatically"
                                      IsChecked="{Binding AutoSwitchToViewer}"
                                      Margin="0,10,0,0" />

                            <CheckBox Content="Automatically save measurements"
                                      IsChecked="{Binding AutoSaveMeasurements}"
                                      Margin="0,5,0,0" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="Run Measurement" 
                                        Command="{Binding RunMeasurementCommand}" 
                                        IsEnabled="{Binding !IsMeasuring}"
                                        Classes="Primary" 
                                        Width="180" 
                                        Margin="0,15,0,0" />

                                <Button Content="Export to CSV" 
                                        Click="ExportCsvButton_Click"
                                        IsEnabled="{Binding HasCurvePoints}"
                                        Classes="Secondary" 
                                        Width="150" 
                                        Margin="0,15,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Column: Status -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="15" Margin="20,15,10,0" HorizontalAlignment="Stretch">
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="15" Background="#F9F9F9" MinWidth="450" MinHeight="150">
                                <TextBlock Text="{Binding MeasurementStatus}" 
                                           FontFamily="Courier New" 
                                           FontSize="12" 
                                           TextWrapping="Wrap" />
                            </Border>

                            <StackPanel Spacing="5" IsVisible="{Binding IsMeasuringSweep}">
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="Measurement Progress" FontSize="11" FontWeight="SemiBold" Foreground="#666666" />
                                    <TextBlock Grid.Column="1" Text="{Binding MeasurementProgressText}" FontSize="11" FontWeight="SemiBold" Foreground="#333333" />
                                </Grid>
                                <ProgressBar Minimum="0" 
                                             Maximum="100" 
                                             Value="{Binding MeasurementProgress}" 
                                             IsIndeterminate="{Binding IsProgressIndeterminate}" 
                                             Height="8" 
                                             CornerRadius="4"
                                             Foreground="Black"
                                             Background="#E0E0E0" />
                            </StackPanel>

                            <TextBlock Text="{Binding WarningMessage}" 
                                       Foreground="#E65100" 
                                       TextWrapping="Wrap" 
                                       MaxWidth="400" 
                                       HorizontalAlignment="Left"
                                       IsVisible="{Binding HasWarningMessage}" />

                            <TextBlock Text="{Binding ErrorMessage}" 
                                       Foreground="#D32F2F" 
                                       TextWrapping="Wrap" 
                                       MaxWidth="400" 
                                       HorizontalAlignment="Left" />

                            <CheckBox Content="Logarithmic Y-Axis" IsChecked="{Binding IsMeasurementLogarithmic}" Margin="0,10,0,0" />
                            <Border Height="400" HorizontalAlignment="Stretch">
                                <views:CurvePlotView Title="Live Measurement Preview"
                                                     XAxisLabel="{Binding XAxisTitle}"
                                                     YAxisLabel="{Binding YAxisTitle}"
                                                     Series="{Binding PlotSeries}"
                                                     Points="{Binding CurvePoints}"
                                                     PlotStyle="{Binding SelectedPlotStyle}"
                                                     LogarithmicY="{Binding IsMeasurementLogarithmic}" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Wafermap">
                <ScrollViewer Margin="20" HorizontalScrollBarVisibility="Disabled">
                    <Grid ColumnDefinitions="45*,10*,45*">
                        <StackPanel Grid.Column="0" Spacing="20">
                            <TextBlock Text="Automatic Wafer Scan" FontSize="20" FontWeight="Bold" Margin="0,0,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="Note: The automatic wafer scan will execute the measurement plan currently selected in the 'Measurements' tab at each target contact." FontStyle="Italic" TextWrapping="Wrap" Foreground="#666666" Margin="0,0,0,10" />
                            
                            <!-- Side-by-Side: Configuration Inputs (Left) and 5x5 Sub-cell Grid (Right) -->
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto" Margin="0,10,0,0" IsEnabled="{Binding !IsScanningWafer}">
                                <!-- Left: Contacts, Delay, Buttons -->
                                <StackPanel Grid.Column="0" Spacing="15" Margin="0,0,30,0" VerticalAlignment="Top" Width="260">
                                    <!-- Target Contacts -->
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Target Contacts (1-6):" FontSize="14" FontWeight="SemiBold" />
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,5">
                                            <TextBox Grid.Column="0" Text="{Binding TargetScanContacts}" PlaceholderText="e.g. 1, 2, 3" IsEnabled="{Binding !IsAllContactsChecked}" Height="32" VerticalContentAlignment="Center" />
                                            <CheckBox Grid.Column="1" Content="All" IsChecked="{Binding IsAllContactsChecked}" Margin="10,0,0,0" VerticalAlignment="Center" />
                                        </Grid>
                                    </StackPanel>

                                    <!-- Movement Delay -->
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Movement Delay (ms):" FontSize="14" FontWeight="SemiBold" />
                                        <TextBox Text="{Binding WaferScanDelayMs}" Width="120" HorizontalAlignment="Left" Height="32" VerticalContentAlignment="Center" />
                                    </StackPanel>
                                    
                                    <!-- Buttons -->
                                    <StackPanel Spacing="10" Margin="0,10,0,0">
                                        <Button Content="Start Wafer Scan" Command="{Binding ScanWaferCommand}" Classes="Primary" HorizontalAlignment="Stretch" Height="36" />
                                        <Button Content="Stop Scan" Command="{Binding RequestStopScanCommand}" Classes="Danger" HorizontalAlignment="Stretch" Height="36" />
                                        <Button Content="Move to Start Point" Command="{Binding GoToScanStartCommand}" Classes="Secondary" HorizontalAlignment="Stretch" Height="36" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Right: 5x5 Sub-cells Grid -->
                                <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Top">
                                    <TextBlock Text="Global Sub-cells (Rows/Cols):" FontSize="14" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,5">
                                        <Button Content="Select All" Command="{Binding SelectAllSubCellsCommand}" Classes="Secondary" Padding="10,5" />
                                        <Button Content="Deselect All" Command="{Binding DeselectAllSubCellsCommand}" Classes="Secondary" Padding="10,5" />
                                    </StackPanel>
                                    <Viewbox Stretch="Uniform" HorizontalAlignment="Left" StretchDirection="DownOnly">
                                        <Border Background="#F3F4F6" Padding="10" CornerRadius="8">
                                            <ItemsControl ItemsSource="{Binding SubCells}">
                                                <ItemsControl.Styles>
                                                    <Style Selector="ToggleButton">
                                                        <Setter Property="Background" Value="#FFCDD2" />
                                                    </Style>
                                                    <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                                                        <Setter Property="Background" Value="#C8E6C9" />
                                                    </Style>
                                                    <Style Selector="ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                        <Setter Property="Background" Value="#EF9A9A" />
                                                    </Style>
                                                    <Style Selector="ToggleButton:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                        <Setter Property="Background" Value="#A5D6A7" />
                                                    </Style>
                                                </ItemsControl.Styles>
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="5" Rows="5" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:SubCellViewModel">
                                                        <Border Width="44" Height="44" Margin="3">
                                                            <ToggleButton IsChecked="{Binding IsSelected}" 
                                                                          IsVisible="{Binding IsValid}" 
                                                                          HorizontalAlignment="Stretch" 
                                                                          VerticalAlignment="Stretch"
                                                                          CornerRadius="4"
                                                                          ToolTip.Tip="{Binding Id}"
                                                                          Padding="0">
                                                                <TextBlock Text="{Binding Id}" FontSize="12" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </ToggleButton>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </Viewbox>
                                </StackPanel>
                            </Grid>

                            <!-- Progress indicators and Scan Log -->
                            <StackPanel Spacing="10" Margin="0,15,0,0">
                                <ProgressBar Value="{Binding WaferScanProgress}" Minimum="0" Maximum="100" Height="20" Foreground="Black" HorizontalAlignment="Stretch" MinWidth="200" />
                                <WrapPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding WaferScanCountText}" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0" />
                                    <TextBlock Text="{Binding WaferScanEstimatedFinish}" Foreground="#666666" VerticalAlignment="Center" />
                                </WrapPanel>
                            </StackPanel>
                            
                            <TextBlock Text="{Binding WaferScanLog}" FontWeight="{Binding WaferScanLogFontWeight}" Foreground="#4B5563" TextWrapping="Wrap" Margin="0,10,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="15">

                            <TextBlock Text="Target Cells:" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0" TextWrapping="Wrap" />
                            <WrapPanel Orientation="Horizontal" IsEnabled="{Binding !IsScanningWafer}">
                                <Button Content="Select All" Command="{Binding SelectAllCellsCommand}" Classes="Secondary" Padding="10,5" Margin="0,0,10,10" />
                                <Button Content="Deselect All" Command="{Binding DeselectAllCellsCommand}" Classes="Secondary" Padding="10,5" Margin="0,0,10,10" />
                            </WrapPanel>
                            
                            <Viewbox Stretch="Uniform" HorizontalAlignment="Left" StretchDirection="DownOnly" IsEnabled="{Binding !IsScanningWafer}">
                                <Border Background="#F3F4F6" Padding="15" CornerRadius="8">
                                <ItemsControl ItemsSource="{Binding WaferCells}">
                                    <ItemsControl.Styles>
                                        <Style Selector="ToggleButton">
                                            <Setter Property="Background" Value="#FFCDD2" />
                                        </Style>
                                        <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                                            <Setter Property="Background" Value="#C8E6C9" />
                                        </Style>
                                        <Style Selector="ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                            <Setter Property="Background" Value="#EF9A9A" />
                                        </Style>
                                        <Style Selector="ToggleButton:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                            <Setter Property="Background" Value="#A5D6A7" />
                                        </Style>
                                    </ItemsControl.Styles>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="16" Rows="16" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:WaferCellViewModel">
                                            <Border Width="38" Height="38" Margin="1">
                                                <ToggleButton IsChecked="{Binding IsSelected}" 
                                                              IsVisible="{Binding IsValid}" 
                                                              HorizontalAlignment="Stretch" 
                                                              VerticalAlignment="Stretch"
                                                              ToolTip.Tip="{Binding Id}"
                                                              CornerRadius="4"
                                                              Padding="0">
                                                    <TextBlock Text="{Binding Id}" FontSize="9" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </ToggleButton>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                            </Viewbox>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Result">
                <Grid>
                    <!-- Empty State Placeholder (No Folder Loaded) -->
                    <Border IsVisible="{Binding !IsResultFolderLoaded}"
                            Background="#F9FAFB"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="40"
                            Margin="30"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="500">
                        <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- Visual Circle / Icon Representative -->
                            <Border Width="80" Height="80" CornerRadius="40" Background="#EEF2F6" HorizontalAlignment="Center">
                                <Path Fill="#6B7280" Data="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" Width="36" Height="36" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            
                            <TextBlock Text="No wafer map folder loaded" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="#1F2937" 
                                       HorizontalAlignment="Center" 
                                       TextAlignment="Center"/>
                                       
                            <TextBlock Text="Please load a wafer scan folder with the CSV measurement results to display the wafer map visualization and I-V curves." 
                                       TextWrapping="Wrap" 
                                       FontSize="14" 
                                       Foreground="#4B5563" 
                                       HorizontalAlignment="Center" 
                                       TextAlignment="Center"
                                       LineHeight="20"/>
                            
                            <Button Content="Load scan folder" 
                                    Click="LoadResultFolderButton_Click" 
                                    Classes="Primary" 
                                    Padding="20,10" 
                                    HorizontalAlignment="Center" 
                                    Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Normal Result UI -->
                    <ScrollViewer IsVisible="{Binding IsResultFolderLoaded}" Margin="20" HorizontalScrollBarVisibility="Disabled">
                        <Grid RowDefinitions="Auto,*" Margin="10">
                        <!-- Top Bar -->
                        <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                            <Button Content="Load Scan Folder" Click="LoadResultFolderButton_Click" Classes="Primary" Padding="10,5" Margin="0,0,20,0" />
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <TextBlock Text="Visualization Metric:" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding AvailableResultMetrics}"
                                          SelectedItem="{Binding SelectedResultMetric}"
                                          Width="200" />
                            </StackPanel>
                        </WrapPanel>

                        <!-- Main 3-Column Layout -->
                        <Grid Grid.Row="1" ColumnDefinitions="Auto, Auto, *">
                            <!-- Left: 16x16 Wafermap -->
                            <StackPanel Grid.Column="0" Spacing="10" Margin="0,0,20,0">
                                <TextBlock Text="Wafer Cells (16x16)" FontSize="16" FontWeight="SemiBold" />
                                <Viewbox Stretch="Uniform" HorizontalAlignment="Left" StretchDirection="DownOnly" MaxWidth="500">
                                    <Border Background="#F3F4F6" Padding="15" CornerRadius="8">
                                        <ItemsControl ItemsSource="{Binding ResultCells}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="16" Rows="16" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ResultCellViewModel">
                                                    <Border Width="38" Height="38" Margin="1" Background="{Binding Color}" CornerRadius="4" IsVisible="{Binding IsValid}">
                                                        <ToolTip.Tip>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Id}" FontWeight="Bold" />
                                                                <TextBlock Text="{Binding FormattedValue}" />
                                                            </StackPanel>
                                                        </ToolTip.Tip>
                                                        <Grid>
                                                            <RadioButton GroupName="ResultCells" 
                                                                         IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectedResultCell, Mode=OneWayToSource, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                         Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SetSelectedResultCellCommand}"
                                                                         CommandParameter="{Binding}"
                                                                         Opacity="0"
                                                                         HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                                            <TextBlock Text="{Binding Id}" FontSize="9" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </Viewbox>
                            </StackPanel>

                            <!-- Middle: 5x5 SubCells & Contacts -->
                            <StackPanel Grid.Column="1" Spacing="20" Margin="0,0,20,0">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Sub-Cells (5x5)" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock Text="Select a cell on the left first." IsVisible="{Binding SelectedResultCell, Converter={x:Static ObjectConverters.IsNull}}" FontStyle="Italic" Foreground="Gray" />
                                    
                                    <Viewbox Stretch="Uniform" HorizontalAlignment="Left" StretchDirection="DownOnly" MaxWidth="250" IsVisible="{Binding SelectedResultCell, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <Border Background="#F3F4F6" Padding="10" CornerRadius="8">
                                            <ItemsControl ItemsSource="{Binding SelectedResultCell.SubCells}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="5" Rows="5" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:ResultSubCellViewModel">
                                                        <Border Width="44" Height="44" Margin="3" Background="{Binding Color}" CornerRadius="4" IsVisible="{Binding IsValid}">
                                                            <ToolTip.Tip>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Id}" FontWeight="Bold" />
                                                                    <TextBlock Text="{Binding FormattedValue}" />
                                                                </StackPanel>
                                                            </ToolTip.Tip>
                                                            <Grid>
                                                                <RadioButton GroupName="ResultSubCells"
                                                                             Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SetSelectedResultSubCellCommand}"
                                                                             CommandParameter="{Binding}"
                                                                             Opacity="0"
                                                                             HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                                                <TextBlock Text="{Binding Id}" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </Viewbox>
                                </StackPanel>

                                <StackPanel Spacing="10" IsVisible="{Binding SelectedResultSubCell, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <TextBlock Text="Contacts" FontSize="16" FontWeight="SemiBold" />
                                    <ListBox ItemsSource="{Binding SelectedResultSubCell.Contacts}"
                                             SelectedItem="{Binding SelectedResultContact}"
                                             Background="Transparent"
                                             BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ResultContactViewModel">
                                                <Border Background="#E5E7EB" CornerRadius="4" Padding="10,5" Margin="0,2">
                                                    <ToolTip.Tip>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" />
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectedResultMetric}" FontWeight="SemiBold"/>
                                                                <TextBlock Text=":"/>
                                                                <TextBlock Text="{Binding FormattedValue}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </ToolTip.Tip>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Right: CurvePlotView -->
                            <StackPanel Grid.Column="2" Spacing="10">
                                <TextBlock Text="I-V Curve" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="Select a contact to view its curve." IsVisible="{Binding SelectedResultContact, Converter={x:Static ObjectConverters.IsNull}}" FontStyle="Italic" Foreground="Gray" />
                                
                                <ScrollViewer IsVisible="{Binding SelectedResultContact, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <StackPanel Spacing="16">
                                        <views:CurvePlotView Title="{Binding SelectedResultContact.DisplayName}"
                                                             XAxisLabel="Voltage (V)"
                                                             YAxisLabel="Current (A)"
                                                             Points="{Binding SelectedResultContact.CurveData}"
                                                             Height="300" />

                                        <views:CurvePlotView Title="I/U Curve - Logarithmic"
                                                             XAxisLabel="Voltage (V)"
                                                             YAxisLabel="Current (A)"
                                                             Points="{Binding SelectedResultContact.CurveData}"
                                                             LogarithmicY="True"
                                                             Height="300" />
                                    </StackPanel>
                                </ScrollViewer>
                            </StackPanel>

                        </Grid>
                    </Grid>
                </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
        </DockPanel>

        <!-- Cancel Prompt Overlay -->
        <Grid Background="#80000000" IsVisible="{Binding IsCancelPromptVisible}" ZIndex="100">
            <Border Background="White" CornerRadius="8" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400" BorderBrush="LightGray" BorderThickness="1">
                <StackPanel Spacing="20">
                    <TextBlock Text="Cancel Wafer Scan?" FontSize="20" FontWeight="Bold" Foreground="#D32F2F" />
                    <TextBlock Text="Are you sure you want to stop the scan? All further measurements will be aborted." TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right">
                        <Button Content="No, Continue" Command="{Binding CancelStopRequestCommand}" Classes="Secondary" />
                        <Button Content="Yes, Stop Scan" Command="{Binding ConfirmStopScanCommand}" Classes="Danger" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Error Popup Overlay -->
        <Grid Background="#80000000" IsVisible="{Binding IsErrorPopupVisible}" ZIndex="100">
            <Border Background="White" CornerRadius="8" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400" BorderBrush="LightGray" BorderThickness="1">
                <StackPanel Spacing="20">
                    <TextBlock Text="Scan Error" FontSize="20" FontWeight="Bold" Foreground="#D32F2F" />
                    <TextBlock Text="{Binding PopupErrorMessage}" TextWrapping="Wrap" />
                    <Button Content="OK" Command="{Binding CloseErrorPopupCommand}" Classes="Secondary" HorizontalAlignment="Right" Width="100" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Alignment Warning Overlay -->
        <Grid Background="#80000000" IsVisible="{Binding IsAlignmentWarningVisible}" ZIndex="100">
            <Border Background="White" CornerRadius="8" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400" BorderBrush="LightGray" BorderThickness="1">
                <StackPanel Spacing="20">
                    <TextBlock Text="Alignment Confirmation" FontSize="20" FontWeight="Bold" Foreground="#1F2937" />
                    <TextBlock Text="Have you correctly aligned the wafer to cell 0104 and set the home position?" TextWrapping="Wrap" />
                    
                    <Border Background="#F3F4F6" CornerRadius="6" Padding="10,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Path Fill="#4B5563" Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="Plan to execute:" FontWeight="SemiBold" Foreground="#4B5563" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedPlan.Name}" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CancelAlignmentWarningCommand}" Classes="Secondary" />
                        <Button Content="Yes, Start Scan" Command="{Binding ProceedWithScanCommand}" Classes="Primary" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Centered Toast Notification -->
        <Border x:Name="ToastBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,50"
                Background="#1E1E1E"
                CornerRadius="20"
                Padding="16,10"
                Opacity="0"
                IsVisible="False"
                ZIndex="1000">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25"/>
                </Transitions>
            </Border.Transitions>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                      Fill="#EF4444" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                <TextBlock x:Name="ToastTextBlock" Foreground="White" FontSize="13" VerticalAlignment="Center" MaxWidth="300" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>