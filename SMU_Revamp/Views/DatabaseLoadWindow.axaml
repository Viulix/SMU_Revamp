<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SMU_Revamp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="SMU_Revamp.Views.DatabaseLoadWindow"
        x:DataType="vm:DatabaseLoadViewModel"
        Icon="/Assets/smu_logo.png"
        Title="Load Measurement from Database"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        CanResize="True"
        Width="800"
        Height="600">
        
    <Grid RowDefinitions="Auto, *, Auto" Margin="20">
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Database Measurements" FontSize="20" FontWeight="Bold" />
            <TextBlock Text="{Binding StatusMessage}" Foreground="#666666" Margin="0,5,0,0" />
            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" Height="4" Margin="0,10,0,0" />
        </StackPanel>

        <!-- List -->
        <Border Grid.Row="1" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
            <TreeView ItemsSource="{Binding RootNodes}" 
                      SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                      Background="White">
                <TreeView.Styles>
                    <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron">
                        <Setter Property="RenderTransform" Value="scale(1.5)" />
                        <Setter Property="Margin" Value="5" />
                    </Style>
                </TreeView.Styles>
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="2">
                            <TextBlock Text="{Binding Header}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Measurement.SourceFilename}" IsVisible="{Binding IsMeasurement}" FontSize="10" Foreground="Gray" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0" Spacing="10">
            <Button Content="Cancel" Click="CancelButton_Click" Classes="Tertiary" Padding="15,8" />
            <Button Content="Load as Wafermap" Command="{Binding LoadWafermapCommand}" Classes="Secondary" Padding="15,8" IsVisible="{Binding SelectedNode.IsFolderNode}" />
            <Button Content="Load Selected" Command="{Binding LoadCommand}" Classes="Primary" Padding="15,8" />
        </StackPanel>
    </Grid>
</Window>
