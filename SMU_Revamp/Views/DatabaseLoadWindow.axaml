<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SMU_Revamp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="SMU_Revamp.Views.DatabaseLoadWindow"
        x:DataType="vm:DatabaseLoadViewModel"
        Icon="/Assets/tf_logo_rgb_en.ico"
        Title="Load Measurement from Database"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        CanResize="True"
        Width="800"
        Height="600">
        
    <Grid RowDefinitions="Auto, *, Auto" Margin="20">
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Database Measurements" FontSize="20" FontWeight="Bold" />
            <TextBlock Text="{Binding StatusMessage}" Foreground="#666666" Margin="0,5,0,0" />
            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" Height="4" Margin="0,10,0,0" />
        </StackPanel>

        <!-- List -->
        <Border Grid.Row="1" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
            <ListBox ItemsSource="{Binding Measurements}" 
                     SelectedItem="{Binding SelectedMeasurement}"
                     Background="White">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*, 150, 200" Margin="5">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding PlanName}" FontWeight="Bold" />
                                <TextBlock Text="{Binding SampleName}" Foreground="#555555" FontSize="12" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding SourceFilename}" FontSize="10" Foreground="#888888" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0" Spacing="10">
            <Button Content="Cancel" Click="CancelButton_Click" Classes="Tertiary" Padding="15,8" />
            <Button Content="Load Selected" Command="{Binding LoadCommand}" Classes="Primary" Padding="15,8" />
        </StackPanel>
    </Grid>
</Window>
