<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SMU_Revamp.ViewModels"
             xmlns:views="using:SMU_Revamp.Views"
             x:Class="SMU_Revamp.Views.Controls.ResultCurveControl"
             x:DataType="vm:MainWindowViewModel">
    <Border Background="#FFFFFF" BoxShadow="0 4 15 0 #15000000" CornerRadius="8" Padding="20" VerticalAlignment="Top">
        <StackPanel Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="I-V Curve" FontSize="16" FontWeight="SemiBold" />
                <Border Background="#EEF2F6" CornerRadius="4" Padding="8,4" IsVisible="{Binding SelectedResultContact, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock FontWeight="Bold" Foreground="#1F2937">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}Cell: {0} | Sub: {1} | {2}">
                                <Binding Path="SelectedResultCell.Id" FallbackValue="-" />
                                <Binding Path="SelectedResultSubCell.Id" FallbackValue="-" />
                                <Binding Path="SelectedResultContact.DisplayName" FallbackValue="-" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Border>
                <Button Content="⛶ View Large" 
                        Click="EnlargeResultPlotButton_Click" 
                        IsVisible="{Binding SelectedResultContact, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Classes="Secondary" 
                        Padding="10,5" />
            </StackPanel>
            <TextBlock Text="Select a contact to view its curve." IsVisible="{Binding SelectedResultContact, Converter={x:Static ObjectConverters.IsNull}}" FontStyle="Italic" Foreground="Gray" />
            
            <ScrollViewer IsVisible="{Binding SelectedResultContact, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TabControl Margin="0,10,0,0">
                    <TabItem Header="Linear Plot">
                        <views:CurvePlotView Title="{Binding SelectedResultContact.DisplayName}"
                                             XAxisLabel="Voltage (V)"
                                             YAxisLabel="Current (A)"
                                             Points="{Binding SelectedResultContact.CurveData}"
                                             Height="400" />
                    </TabItem>
                    <TabItem Header="Logarithmic Plot">
                        <views:CurvePlotView Title="I/U Curve - Logarithmic"
                                             XAxisLabel="Voltage (V)"
                                             YAxisLabel="Current (A)"
                                             Points="{Binding SelectedResultContact.CurveData}"
                                             LogarithmicY="True"
                                             Height="400" />
                    </TabItem>
                    <TabItem Header="Check Details">
                        <ScrollViewer Height="400" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="15" Margin="0,10,0,0">
                                <!-- Overall Score Card -->
                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="15">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <StackPanel Spacing="5" Grid.Column="0">
                                            <TextBlock Text="Classification" FontSize="12" Foreground="#64748B" FontWeight="Medium" />
                                            <TextBlock Text="{Binding SelectedMemristorCheckResult.Classification}" FontSize="18" FontWeight="Bold" Foreground="#1E293B" />
                                        </StackPanel>
                                        <StackPanel Spacing="5" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Border Background="#EFF6FF" BorderBrush="#3B82F6" BorderThickness="1" CornerRadius="6" Padding="10,6">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="Score3:" FontSize="12" Foreground="#2563EB" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding SelectedMemristorCheckResult.FormattedScore3}" FontSize="16" FontWeight="Bold" Foreground="#1D4ED8" VerticalAlignment="Center" />
                                                    <TextBlock Text="/ 3.00" FontSize="11" Foreground="#3B82F6" VerticalAlignment="Bottom" Margin="0,0,0,1" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Flags / Indicators -->
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Indicators &amp; Warnings" FontSize="13" FontWeight="SemiBold" Foreground="#475569" />
                                    
                                    <!-- When there are flags -->
                                    <ItemsControl ItemsSource="{Binding SelectedMemristorCheckResult.UserFlags}" 
                                                  IsVisible="{Binding SelectedMemristorCheckResult.Flags.Count}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="12" Padding="8,4" Margin="0,0,6,6">
                                                    <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- When there are NO flags -->
                                    <Border Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1" CornerRadius="6" Padding="10,8"
                                            IsVisible="{Binding !SelectedMemristorCheckResult.Flags.Count}">
                                        <TextBlock Text="✓ All checks passed - Strong memristive signatures" Foreground="#166534" FontSize="12" FontWeight="Medium" />
                                    </Border>
                                </StackPanel>

                                <!-- Parameters Grid -->
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Detailed Metrics" FontSize="13" FontWeight="SemiBold" Foreground="#475569" />
                                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="2*, 3*">
                                            <Grid.Styles>
                                                <!-- Styling row border and backgrounds -->
                                                <Style Selector="TextBlock.header">
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                    <Setter Property="Foreground" Value="#475569" />
                                                    <Setter Property="Padding" Value="12,8" />
                                                    <Setter Property="FontSize" Value="12" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                </Style>
                                                <Style Selector="TextBlock.value">
                                                    <Setter Property="Foreground" Value="#1E293B" />
                                                    <Setter Property="Padding" Value="12,8" />
                                                    <Setter Property="FontSize" Value="12" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                </Style>
                                            </Grid.Styles>

                                            <!-- Row 0: SNR -->
                                            <Border Grid.Row="0" Grid.Column="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                                <TextBlock Text="Signal-to-Noise Ratio (SNR)" Classes="header" />
                                            </Border>
                                            <Border Grid.Row="0" Grid.Column="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                                <TextBlock Text="{Binding SelectedMemristorCheckResult.FormattedSnr}" Classes="value" FontWeight="Medium" />
                                            </Border>

                                            <!-- Row 1: Noise Std -->
                                            <Border Grid.Row="1" Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                                <TextBlock Text="Noise Std Dev (Noise Std)" Classes="header" />
                                            </Border>
                                            <Border Grid.Row="1" Grid.Column="1" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                                <TextBlock Text="{Binding SelectedMemristorCheckResult.FormattedNoiseStd}" Classes="value" />
                                            </Border>

                                            <!-- Row 2: Current Scale -->
                                            <Border Grid.Row="2" Grid.Column="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                                <TextBlock Text="Current Scale" Classes="header" />
                                            </Border>
                                            <Border Grid.Row="2" Grid.Column="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                                <TextBlock Text="{Binding SelectedMemristorCheckResult.FormattedCurrentScale}" Classes="value" />
                                            </Border>

                                            <!-- Row 3: Nonlinearity -->
                                            <Border Grid.Row="3" Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                                <TextBlock Text="Nonlinearity" Classes="header" />
                                            </Border>
                                            <Border Grid.Row="3" Grid.Column="1" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                                <TextBlock Text="{Binding SelectedMemristorCheckResult.FormattedNonlinearity}" Classes="value" />
                                            </Border>

                                            <!-- Row 4: Hysteresis -->
                                            <Border Grid.Row="4" Grid.Column="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                                <TextBlock Text="Hysteresis Area (Hysteresis)" Classes="header" />
                                            </Border>
                                            <Border Grid.Row="4" Grid.Column="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                                <TextBlock Text="{Binding SelectedMemristorCheckResult.FormattedHysteresis}" Classes="value" />
                                            </Border>

                                            <!-- Row 5: Branch Separation SNR -->
                                            <Border Grid.Row="5" Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                                <TextBlock Text="Branch Separation SNR" Classes="header" />
                                            </Border>
                                            <Border Grid.Row="5" Grid.Column="1" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                                <TextBlock Text="{Binding SelectedMemristorCheckResult.FormattedBranchSeparationSnr}" Classes="value" />
                                            </Border>

                                            <!-- Row 6: Pinch Error -->
                                            <Border Grid.Row="6" Grid.Column="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                                <TextBlock Text="Pinch Error" Classes="header" />
                                            </Border>
                                            <Border Grid.Row="6" Grid.Column="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                                <TextBlock Text="{Binding SelectedMemristorCheckResult.FormattedPinchError}" Classes="value" />
                                            </Border>

                                            <!-- Row 7: Origin Offset -->
                                            <Border Grid.Row="7" Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                                <TextBlock Text="Origin Offset" Classes="header" />
                                            </Border>
                                            <Border Grid.Row="7" Grid.Column="1" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                                <TextBlock Text="{Binding SelectedMemristorCheckResult.FormattedOriginOffset}" Classes="value" />
                                            </Border>

                                            <!-- Row 8: Roughness -->
                                            <Border Grid.Row="8" Grid.Column="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                                <TextBlock Text="Roughness" Classes="header" />
                                            </Border>
                                            <Border Grid.Row="8" Grid.Column="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                                <TextBlock Text="{Binding SelectedMemristorCheckResult.FormattedRoughness}" Classes="value" />
                                            </Border>

                                            <!-- Row 9: Sweep Counts -->
                                            <Border Grid.Row="9" Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                                                <TextBlock Text="Data Points (Up / Down Sweep)" Classes="header" />
                                            </Border>
                                            <Border Grid.Row="9" Grid.Column="1" BorderBrush="#E2E8F0" BorderThickness="0,0,0,0">
                                                <TextBlock Text="{Binding SelectedMemristorCheckResult.FormattedSweepCounts}" Classes="value" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </ScrollViewer>
        </StackPanel>
    </Border>
</UserControl>
