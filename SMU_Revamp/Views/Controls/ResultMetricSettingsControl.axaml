<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SMU_Revamp.ViewModels"
             x:Class="SMU_Revamp.Views.Controls.ResultMetricSettingsControl"
             x:DataType="vm:MainWindowViewModel">
    <Border Background="#FFFFFF" BoxShadow="0 4 15 0 #15000000" CornerRadius="8" Padding="20" Margin="0,0,0,20">
        <StackPanel Spacing="15">
            <TextBlock Text="Metric Settings" FontSize="18" FontWeight="SemiBold" />
            <WrapPanel Orientation="Horizontal">
                <Button Content="Load Scan Folder" Click="OnLoadFolderClick" Classes="Primary" Padding="10,5" Margin="0,0,10,0" VerticalAlignment="Center" />
                <Button Content="Load from DB" Click="OnLoadDatabaseClick" Classes="Secondary" Padding="10,5" Margin="0,0,20,0" VerticalAlignment="Center" />
                
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Visualization Metric:" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding AvailableResultMetrics}"
                              SelectedItem="{Binding SelectedResultMetric}"
                              Width="200" />
                              
                    <StackPanel Orientation="Horizontal" Spacing="5" IsVisible="{Binding IsGapMetricSelected}">
                        <TextBlock Text="Target V:" VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding GapTargetVoltage}" 
                                       FormatString="0.00" 
                                       Increment="0.1" 
                                       Width="130" 
                                       Height="32" />
                    </StackPanel>

                    <CheckBox Content="Use Average Score" 
                              IsChecked="{Binding UseAverageForMemristorCheck}"
                              IsVisible="{Binding IsMemristorCheckSelected}"
                              Margin="10,0,0,0"
                              VerticalAlignment="Center" />

                    <Button Content="Weights..." 
                            IsVisible="{Binding IsMemristorCheckSelected}"
                            Margin="5,0,0,0"
                            Padding="8,4"
                            VerticalAlignment="Center">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <StackPanel Spacing="12" Width="260">
                                    <TextBlock Text="Memristor Check Weights" FontWeight="Bold" FontSize="14" Margin="0,0,0,5" />
                                    
                                    <Grid ColumnDefinitions="*,80" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                                        <!-- SNR -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="SNR Weight:" VerticalAlignment="Center" Margin="0,0,0,8" />
                                        <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding MemristorWeightSnr}" Minimum="0" Maximum="1" Increment="0.05" FormatString="0.00" Height="28" ShowButtonSpinner="False" Margin="0,0,0,8" />
                                        
                                        <!-- Nonlinearity -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Nonlinearity:" VerticalAlignment="Center" Margin="0,0,0,8" />
                                        <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding MemristorWeightNonlinearity}" Minimum="0" Maximum="1" Increment="0.05" FormatString="0.00" Height="28" ShowButtonSpinner="False" Margin="0,0,0,8" />
                                        
                                        <!-- Hysteresis -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Hysteresis:" VerticalAlignment="Center" Margin="0,0,0,8" />
                                        <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding MemristorWeightHysteresis}" Minimum="0" Maximum="1" Increment="0.05" FormatString="0.00" Height="28" ShowButtonSpinner="False" Margin="0,0,0,8" />
                                        
                                        <!-- Branch Separation -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Branch Sep:" VerticalAlignment="Center" Margin="0,0,0,8" />
                                        <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding MemristorWeightBranchSep}" Minimum="0" Maximum="1" Increment="0.05" FormatString="0.00" Height="28" ShowButtonSpinner="False" Margin="0,0,0,8" />
                                        
                                        <!-- Pinch -->
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Pinch Error:" VerticalAlignment="Center" Margin="0,0,0,8" />
                                        <NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding MemristorWeightPinch}" Minimum="0" Maximum="1" Increment="0.05" FormatString="0.00" Height="28" ShowButtonSpinner="False" Margin="0,0,0,8" />
                                        
                                        <!-- Smoothness -->
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Smoothness:" VerticalAlignment="Center" Margin="0,0,0,8" />
                                        <NumericUpDown Grid.Row="5" Grid.Column="1" Value="{Binding MemristorWeightSmoothness}" Minimum="0" Maximum="1" Increment="0.05" FormatString="0.00" Height="28" ShowButtonSpinner="False" Margin="0,0,0,8" />
                                    </Grid>
                                    
                                    <TextBlock Text="Note: Weights are automatically normalized." FontSize="10" FontStyle="Italic" Foreground="Gray" Margin="0,5,0,0" TextWrapping="Wrap" />
                                    
                                    <Button Content="Reset to Default" 
                                            Command="{Binding ResetMemristorWeightsCommand}" 
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Margin="0,5,0,0"
                                            Classes="Secondary" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Color Low:" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding AvailableHeatmapColors}"
                              SelectedItem="{Binding SelectedHeatmapColorLow}"
                              Width="120" />
                    <TextBlock Text="Color High:" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding AvailableHeatmapColors}"
                              SelectedItem="{Binding SelectedHeatmapColorHigh}"
                              Width="120" />
                </StackPanel>
            </WrapPanel>
        </StackPanel>
    </Border>
</UserControl>
