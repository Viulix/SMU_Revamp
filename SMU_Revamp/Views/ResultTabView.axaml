<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SMU_Revamp.ViewModels"
             xmlns:views="using:SMU_Revamp.Views"
             xmlns:models="using:SMU_Revamp.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:controls="using:SMU_Revamp.Views.Controls"
             x:Class="SMU_Revamp.Views.ResultTabView"
             x:DataType="vm:MainWindowViewModel">
    <Grid>
        <!-- Empty State Placeholder (No Folder Loaded) -->
        <controls:ResultEmptyStateControl IsVisible="{Binding !IsResultFolderLoaded}"
                                          LoadFolderRequested="LoadResultFolderButton_Click"
                                          LoadDatabaseRequested="LoadResultFromDatabaseButton_Click" />


        <!-- Loading Overlay -->
        <Border IsVisible="{Binding IsLoadingResultData}"
                Background="#DDFFFFFF"
                ZIndex="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                <TextBlock Text="Loading &amp; Calculating Wafermap..." FontSize="20" FontWeight="SemiBold" Foreground="#1F2937" HorizontalAlignment="Center" />
                <ProgressBar IsIndeterminate="True" Width="250" Height="6" CornerRadius="3" Foreground="#2563EB" Background="#E5E7EB" />
                <TextBlock Text="Please wait while measurements are parsed." FontSize="14" Foreground="#4B5563" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Normal Result UI -->
        <ScrollViewer IsVisible="{Binding IsResultFolderLoaded}" Margin="20" HorizontalScrollBarVisibility="Disabled">
            <Grid RowDefinitions="Auto,*" Margin="10">
                <!-- Top Bar / Metric Settings -->
                <controls:ResultMetricSettingsControl Grid.Row="0"
                                                      LoadFolderRequested="LoadResultFolderButton_Click"
                                                      LoadDatabaseRequested="LoadResultFromDatabaseButton_Click" />

                <!-- Main 3-Column Layout -->
                <Grid Grid.Row="1" ColumnDefinitions="5*, 2*, 5*">
                    <!-- Left: 16x16 Wafermap -->
                    <controls:ResultWafermapControl Grid.Column="0" />

                    <!-- Middle: 5x5 SubCells & Contacts -->
                    <controls:ResultSubCellsControl Grid.Column="1" />

                    <!-- Right: CurvePlotView -->
                    <controls:ResultCurveControl Grid.Column="2" />
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
