<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:SMU_Revamp.Views"
        x:Class="SMU_Revamp.Views.EnlargedResultPlotWindow"
        Title="Enlarged Plot"
        Width="1000" Height="800"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/smu_logo.png">
    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Background="#F3F4F6" Padding="15,10">
            <TextBlock x:Name="PlotTitleText" Text="Enlarged Plot" FontSize="18" FontWeight="Bold" Foreground="#1F2937" />
        </Border>
        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Linear Plot">
                <views:CurvePlotView x:Name="LinearPlot"
                                     XAxisLabel="Voltage (V)"
                                     YAxisLabel="Current (A)" />
            </TabItem>
            <TabItem Header="Logarithmic Plot">
                <views:CurvePlotView x:Name="LogPlot"
                                     XAxisLabel="Voltage (V)"
                                     YAxisLabel="Current (A)"
                                     LogarithmicY="True" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
