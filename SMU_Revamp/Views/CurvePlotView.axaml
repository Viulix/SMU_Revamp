<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ScottPlot="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
             x:Class="SMU_Revamp.Views.CurvePlotView">
    <Border Background="#FFFFFF" CornerRadius="10" Padding="12" BorderBrush="#E5E7EB" BorderThickness="1">
        <Grid Name="ContainerGrid">
            <ScottPlot:AvaPlot Name="AvaPlot" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
    </Border>
</UserControl>