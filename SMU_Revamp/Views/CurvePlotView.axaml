<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SMU_Revamp.Views.CurvePlotView">
    <Border Background="#FFFFFF"
            CornerRadius="10"
            Padding="12"
            BorderBrush="#E5E7EB"
            BorderThickness="1">
        <Grid RowDefinitions="Auto,*,Auto">
            <TextBlock x:Name="TitleText"
                       Grid.Row="0"
                       HorizontalAlignment="Center"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Foreground="#202020"
                       Margin="0,0,0,8" />

            <Grid Grid.Row="1" ColumnDefinitions="Auto,*">
                <TextBlock x:Name="YAxisText"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="12"
                           Foreground="#404040"
                           Margin="0,0,8,0">
                    <TextBlock.RenderTransform>
                        <RotateTransform Angle="-90" />
                    </TextBlock.RenderTransform>
                </TextBlock>

                <Canvas x:Name="PlotCanvas"
                        Grid.Column="1"
                        MinHeight="280"
                        ClipToBounds="True" />
            </Grid>

            <TextBlock x:Name="XAxisText"
                       Grid.Row="2"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       Foreground="#404040"
                       Margin="0,8,0,0" />
        </Grid>
    </Border>
</UserControl>
