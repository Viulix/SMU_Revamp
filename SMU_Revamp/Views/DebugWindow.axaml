<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SMU_Revamp.ViewModels"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="600"
        x:Class="SMU_Revamp.Views.DebugWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/tf_logo_rgb_en.ico"
        Title="Configuration"
        WindowStartupLocation="CenterOwner"
        Width="700"
        Height="700">

    <Window.Styles>
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="Background" Value="Black" />
        </Style>
    </Window.Styles>

    <Grid>
        <TabControl Margin="10">
            <!-- Configuration Tab -->
            <TabItem Header="Configuration">
                <ScrollViewer Margin="10" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="20">
                        <WrapPanel Orientation="Horizontal">
                            <!-- Target Contact -->
                            <StackPanel Spacing="10" Margin="10,0,40,20" Width="300">
                                <TextBlock Text="Target Contact" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,5" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Cell:" Width="120" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding TargetCell}" PlaceholderText="e.g. 0101" Width="150" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Row:" Width="120" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding TargetRow}" PlaceholderText="e.g. 1" Width="150" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Column:" Width="120" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding TargetColumn}" PlaceholderText="e.g. 1" Width="150" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Contact:" Width="120" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding TargetContact}" PlaceholderText="e.g. 1" Width="150" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Stay Here:" Width="120" VerticalAlignment="Center" />
                                    <CheckBox IsChecked="{Binding StayHere}" />
                                </StackPanel>
                                <Button Content="Go To Contact" Command="{Binding GoToContactCommand}" Classes="Primary" Width="150" Margin="0,10,0,0" />
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#D32F2F" TextWrapping="Wrap" MaxWidth="300" HorizontalAlignment="Left" />
                            </StackPanel>

                            <!-- Manual Move -->
                            <StackPanel Spacing="10" Margin="10,0,40,20" Width="330">
                                <TextBlock Text="Manual Move" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,5" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="X Position:" Width="120" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding MoveX}" PlaceholderText="e.g. 100" Width="100" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Y Position:" Width="120" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding MoveY}" PlaceholderText="e.g. 100" Width="100" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                                    <Button Content="Move Relative" Command="{Binding MoveRelativeCommand}" Classes="Secondary" Width="150" />
                                    <Button Content="Move Absolute" Command="{Binding MoveAbsoluteCommand}" Classes="Secondary" Width="150" />
                                </StackPanel>
                            </StackPanel>

                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Debug Tab -->
            <TabItem Header="Debug">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Vertical" Margin="10" Spacing="20">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Device Connection Debugger" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="Test VISA connectivity to Prober, Switch Matrix, and SMU devices" FontSize="12" Foreground="#666666" />
                        </StackPanel>

                        <!-- Prober Card -->
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="16" Background="#F9FAFB">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Prober (GPIB0::22::INSTR)" FontSize="14" FontWeight="SemiBold" Foreground="#1F2937" />
                                
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Content="Test Connection" Click="TestProberConnection_Click" Classes="Primary" Padding="15,8" />
                                </StackPanel>
                                
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Output:" FontSize="12" FontWeight="SemiBold" Foreground="#4B5563" />
                                    <TextBox x:Name="ProberOutputTextBox" IsReadOnly="True" Height="80" Padding="10" Text="Ready..." FontFamily="Courier New" FontSize="10" AcceptsReturn="True" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Switch Matrix Card -->
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="16" Background="#F9FAFB">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Switch Matrix (GPIB0::23::INSTR)" FontSize="14" FontWeight="SemiBold" Foreground="#1F2937" />
                                
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Content="Test Connection" Click="TestSwitchConnection_Click" Classes="Primary" Padding="15,8" />
                                    <Button Content="Clear All" Click="ClearAllSwitchConnections_Click" Classes="Secondary" Padding="15,8" />
                                </StackPanel>

                                <Separator Margin="0,4" />

                                <!-- Manual Connection Control -->
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Manual Connection Control:" FontSize="12" FontWeight="SemiBold" Foreground="#4B5563" />
                                    
                                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,10">
                                            <TextBlock Text="Input (1-10):" VerticalAlignment="Center" />
                                            <TextBox x:Name="ConnectionXTextBox" PlaceholderText="e.g. 05" Width="90" />
                                        </StackPanel>
                                        
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,10">
                                            <TextBlock Text="Output (1-12):" VerticalAlignment="Center" />
                                            <TextBox x:Name="ConnectionYTextBox" PlaceholderText="e.g. 01" Width="90" />
                                        </StackPanel>
                                        
                                        <Button Content="Create Connection" Click="CreateSwitchConnection_Click" Classes="Secondary" Padding="15,8" Margin="0,0,8,10" />
                                        <Button Content="Disconnect Route" Click="DisconnectSwitchConnection_Click" Classes="Secondary" Padding="15,8" Margin="0,0,0,10" />
                                    </WrapPanel>
                                    
                                    <TextBlock Text="Note: HP E5250A channel format is Card (1) + Input Port (2 digits) + Output Port (2 digits), e.g. 10501" FontSize="11" Foreground="#6B7280" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Output:" FontSize="12" FontWeight="SemiBold" Foreground="#4B5563" />
                                    <TextBox x:Name="SwitchOutputTextBox" IsReadOnly="True" Height="80" Padding="10" Text="Ready..." FontFamily="Courier New" FontSize="10" AcceptsReturn="True" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- SMU Card -->
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="16" Background="#F9FAFB">
                            <StackPanel Spacing="12">
                                <TextBlock Text="SMU (GPIB0::17::INSTR)" FontSize="14" FontWeight="SemiBold" Foreground="#1F2937" />
                                
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Content="Test Connection" Click="TestSMUConnection_Click" Classes="Primary" Padding="15,8" />
                                    <Button Content="Query Identity" Click="QuerySMUIdentity_Click" Classes="Secondary" Padding="15,8" />
                                </StackPanel>

                                <Separator Margin="0,4" />

                                <!-- Force Voltage Control -->
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Force Voltage Control:" FontSize="12" FontWeight="SemiBold" Foreground="#4B5563" />
                                    
                                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Channel -->
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,10">
                                            <TextBlock Text="Ch:" VerticalAlignment="Center" />
                                            <TextBox x:Name="SmuChannelTextBox" Text="2" PlaceholderText="e.g. 2" Width="50" />
                                        </StackPanel>
                                        
                                        <!-- Voltage -->
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,10">
                                            <TextBlock Text="Volt (V):" VerticalAlignment="Center" />
                                            <TextBox x:Name="SmuVoltageTextBox" Text="0.0" PlaceholderText="e.g. 1.5" Width="70" />
                                        </StackPanel>
                                        
                                        <!-- Compliance -->
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,10">
                                            <TextBlock Text="Comp (A):" VerticalAlignment="Center" />
                                            <TextBox x:Name="SmuComplianceTextBox" Text="0.1" PlaceholderText="e.g. 0.1" Width="70" />
                                        </StackPanel>
                                        
                                        <!-- Duration -->
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,10">
                                            <TextBlock Text="Dur (s):" VerticalAlignment="Center" />
                                            <TextBox x:Name="SmuDurationTextBox" Text="5" PlaceholderText="e.g. 5" Width="60" />
                                        </StackPanel>
                                        
                                        <!-- Force Voltage Button -->
                                        <Button Content="Force Voltage" Click="ForceSmuVoltage_Click" Classes="Secondary" Padding="15,8" Margin="0,0,0,10" />
                                    </WrapPanel>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Output:" FontSize="12" FontWeight="SemiBold" Foreground="#4B5563" />
                                    <TextBox x:Name="SmuOutputTextBox" IsReadOnly="True" Height="80" Padding="10" Text="Ready..." FontFamily="Courier New" FontSize="10" AcceptsReturn="True" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Action Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Spacing="10" Margin="20">
            <Button Content="Close" Click="CloseButton_Click" Classes="Secondary" Padding="15,8" />
        </StackPanel>

        <!-- Centered Toast Notification -->
        <Border x:Name="ToastBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,30"
                Background="#1E1E1E"
                CornerRadius="20"
                Padding="16,10"
                Opacity="0"
                IsVisible="False"
                ZIndex="1000">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25"/>
                </Transitions>
            </Border.Transitions>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                      Fill="#EF4444" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                <TextBlock x:Name="ToastTextBlock" Foreground="White" FontSize="13" VerticalAlignment="Center" MaxWidth="300" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
