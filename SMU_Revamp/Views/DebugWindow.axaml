<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="SMU_Revamp.Views.DebugWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="Device Debug"
        WindowStartupLocation="CenterOwner"
        Width="600"
        Height="700">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Vertical" Margin="20" Spacing="20">
            <StackPanel Spacing="5">
                <TextBlock Text="Device Connection Debugger" FontSize="18" FontWeight="Bold" />
                <TextBlock Text="Test VISA connectivity to Prober, Switch Matrix, and SMU devices" FontSize="12" Foreground="#666666" />
            </StackPanel>

            <!-- Prober Card -->
            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="16" Background="#F9FAFB">
                <StackPanel Spacing="12">
                    <TextBlock Text="Prober (GPIB0::22::INSTR)" FontSize="14" FontWeight="SemiBold" Foreground="#1F2937" />
                    
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Test Connection" Click="TestProberConnection_Click" Classes="Primary" Padding="15,8" />
                        <Button Content="Query Identity" Click="QueryProberIdentity_Click" Classes="Secondary" Padding="15,8" />
                    </StackPanel>
                    
                    <StackPanel Spacing="6">
                        <TextBlock Text="Output:" FontSize="12" FontWeight="SemiBold" Foreground="#4B5563" />
                        <TextBox x:Name="ProberOutputTextBox" IsReadOnly="True" Height="80" Padding="10" Text="Ready..." FontFamily="Courier New" FontSize="10" AcceptsReturn="True" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Switch Matrix Card -->
            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="16" Background="#F9FAFB">
                <StackPanel Spacing="12">
                    <TextBlock Text="Switch Matrix (GPIB0::23::INSTR)" FontSize="14" FontWeight="SemiBold" Foreground="#1F2937" />
                    
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Test Connection" Click="TestSwitchConnection_Click" Classes="Primary" Padding="15,8" />
                        <Button Content="Query Identity" Click="QuerySwitchIdentity_Click" Classes="Secondary" Padding="15,8" />
                        <Button Content="Read Connection" Click="ReadSwitchConnection_Click" Classes="Secondary" Padding="15,8" />
                        <Button Content="Clear All" Click="ClearAllSwitchConnections_Click" Classes="Secondary" Padding="15,8" />
                    </StackPanel>

                    <Separator Margin="0,4" />

                    <!-- Manual Connection Control -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Manual Connection Control:" FontSize="12" FontWeight="SemiBold" Foreground="#4B5563" />
                        
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,10">
                                <TextBlock Text="Input (1-10):" VerticalAlignment="Center" />
                                <TextBox x:Name="ConnectionXTextBox" PlaceholderText="e.g. 05" Width="90" />
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,10">
                                <TextBlock Text="Output (1-12):" VerticalAlignment="Center" />
                                <TextBox x:Name="ConnectionYTextBox" PlaceholderText="e.g. 01" Width="90" />
                            </StackPanel>
                            
                            <Button Content="Create Connection" Click="CreateSwitchConnection_Click" Classes="Secondary" Padding="15,8" Margin="0,0,8,10" />
                            <Button Content="Disconnect Route" Click="DisconnectSwitchConnection_Click" Classes="Secondary" Padding="15,8" Margin="0,0,0,10" />
                        </WrapPanel>
                        
                        <TextBlock Text="Note: HP E5250A channel format is Card (1) + Input Port (2 digits) + Output Port (2 digits), e.g. 10501" FontSize="11" Foreground="#6B7280" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Output:" FontSize="12" FontWeight="SemiBold" Foreground="#4B5563" />
                        <TextBox x:Name="SwitchOutputTextBox" IsReadOnly="True" Height="80" Padding="10" Text="Ready..." FontFamily="Courier New" FontSize="10" AcceptsReturn="True" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- SMU Card -->
            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="16" Background="#F9FAFB">
                <StackPanel Spacing="12">
                    <TextBlock Text="SMU (GPIB0::17::INSTR)" FontSize="14" FontWeight="SemiBold" Foreground="#1F2937" />
                    
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Test Connection" Click="TestSMUConnection_Click" Classes="Primary" Padding="15,8" />
                        <Button Content="Query Identity" Click="QuerySMUIdentity_Click" Classes="Secondary" Padding="15,8" />
                    </StackPanel>

                    <Separator Margin="0,4" />

                    <!-- Force Voltage Control -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Force Voltage Control:" FontSize="12" FontWeight="SemiBold" Foreground="#4B5563" />
                        
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Channel -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,10">
                                <TextBlock Text="Ch:" VerticalAlignment="Center" />
                                <TextBox x:Name="SmuChannelTextBox" Text="2" PlaceholderText="e.g. 2" Width="50" />
                            </StackPanel>
                            
                            <!-- Voltage -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,10">
                                <TextBlock Text="Volt (V):" VerticalAlignment="Center" />
                                <TextBox x:Name="SmuVoltageTextBox" Text="0.0" PlaceholderText="e.g. 1.5" Width="70" />
                            </StackPanel>
                            
                            <!-- Compliance -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,10">
                                <TextBlock Text="Comp (A):" VerticalAlignment="Center" />
                                <TextBox x:Name="SmuComplianceTextBox" Text="0.1" PlaceholderText="e.g. 0.1" Width="70" />
                            </StackPanel>
                            
                            <!-- Duration -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,10">
                                <TextBlock Text="Dur (s):" VerticalAlignment="Center" />
                                <TextBox x:Name="SmuDurationTextBox" Text="5" PlaceholderText="e.g. 5" Width="60" />
                            </StackPanel>
                            
                            <!-- Force Voltage Button -->
                            <Button Content="Force Voltage" Click="ForceSmuVoltage_Click" Classes="Secondary" Padding="15,8" Margin="0,0,0,10" />
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Output:" FontSize="12" FontWeight="SemiBold" Foreground="#4B5563" />
                        <TextBox x:Name="SmuOutputTextBox" IsReadOnly="True" Height="80" Padding="10" Text="Ready..." FontFamily="Courier New" FontSize="10" AcceptsReturn="True" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
                <Button Content="Close" Click="CloseButton_Click" Classes="Secondary" Padding="15,8" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
