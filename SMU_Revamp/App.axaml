<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SMU_Revamp.App"
             xmlns:local="using:SMU_Revamp"
             RequestedThemeVariant="Light">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />

        <!-- ========================================== -->
        <!-- CONTAINER CARDS (Minimal Dropshadow)       -->
        <!-- ========================================== -->
        <Style Selector="Border.Card">
            <Setter Property="BoxShadow">
                <Setter.Value>
                    <BoxShadows>0 4 16 0 #30000000</BoxShadows>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <!-- ========================================== -->
        <!-- BUTTON DROPSHADOW TEMPLATE                 -->
        <!-- ========================================== -->
        <Style Selector="Button:not(.Tertiary):not(.DiscardBtn)">
            <Setter Property="Theme" Value="{x:Null}"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border CornerRadius="{TemplateBinding CornerRadius}"
                            Background="Transparent"
                            BoxShadow="0 4 10 0 #4C000000">
                        <ContentPresenter x:Name="PART_ContentPresenter"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          CornerRadius="{TemplateBinding CornerRadius}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- ========================================== -->
        <!-- PRIMARY BUTTON (Schwarz mit weißem Text)   -->
        <!-- ========================================== -->
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.Primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#333333"/> <!-- Dunkelgrau -->
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.Primary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A1A1A"/> <!-- Fast Schwarz -->
            <Setter Property="BorderBrush" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- ========================================== -->
        <!-- SECONDARY BUTTON (Weiß mit schwarzem Rand) -->
        <!-- ========================================== -->
        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="0.7"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.Secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F2F2F2"/> <!-- Helles Grau -->
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style Selector="Button.Secondary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#E6E6E6"/> <!-- Etwas dunkleres Grau -->
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <!-- ========================================== -->
        <!-- TERTIARY BUTTON (Transparent / Text-Link)  -->
        <!-- ========================================== -->
        <Style Selector="Button.Tertiary">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.Tertiary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F2F2F2"/> <!-- Leichtes Grau als Highlight -->
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style Selector="Button.Tertiary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#E6E6E6"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <!-- ========================================== -->
        <!-- DANGER BUTTON (Red with white text)        -->
        <!-- ========================================== -->
        <Style Selector="Button.Danger">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#D32F2F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.Danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#B71C1C"/>
            <Setter Property="BorderBrush" Value="#B71C1C"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.Danger:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#8E0000"/>
            <Setter Property="BorderBrush" Value="#8E0000"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- ========================================== -->
        <!-- CHECKBOX STYLING (Black & White)           -->
        <!-- ========================================== -->
        <!-- In FluentTheme, the background of checked CheckBox is Border#NormalRectangle -->
        <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="Black" />
            <Setter Property="BorderBrush" Value="Black" />
        </Style>
        <!-- The checkmark glyph is Path#CheckGlyph -->
        <Style Selector="CheckBox:checked /template/ Path#CheckGlyph">
            <Setter Property="Fill" Value="White" />
        </Style>

    </Application.Styles>
</Application>